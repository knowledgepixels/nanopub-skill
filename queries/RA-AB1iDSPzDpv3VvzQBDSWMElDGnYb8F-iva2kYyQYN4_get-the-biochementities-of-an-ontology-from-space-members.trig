    npx:hasSignature "fx7AX/PZSm3hQ+TnyF+bgz1nmC1CO3z5VYDgXzhgYzjmk+ORKTPXwwgPdeXk6qlpxMZDvLY3/1ld0k1m2jSvW7XFV3IUUkpn53VQkZ+sw3VpKYrMC5EQ+VMv5FwpVZVQ9LezhOuXPNwvJXbEFqD7M1RZcJyKrGb1BOsCAF2qII8=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
}

