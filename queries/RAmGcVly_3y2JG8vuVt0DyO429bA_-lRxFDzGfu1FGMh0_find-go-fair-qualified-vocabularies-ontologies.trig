    npx:hasSignature "JFoiyqhHIERkjLTsy8JI0XJ3pbmHmUL1w0y5vpP+3Jn+hOnpqP7ScXxftjdz4OSDAGLafRb8LgkEgZNYgqCxkP8nurKGZFuiCCUIdYDBeX30w4rFK03MOMLpERnisFIMvcIKSU/OOXQOycyJxL7low4OttinbWIyS1ZFOl6qWPc=";
