    npx:hasSignature "MvqeMgVXKgPt6Ue4+b8s9aI8hhoRybC/mfinEGbCo40SeSS6Ock6A/jF0YDRY1sPaupGCzHaak65UFHOV40PKQVBv7Bq6lu0odPEPrOAVLi/k+9npb/coTfQh6VeHLF2FRmoNYsAjo3ASMpFubzXMfTEZ3E0A3rnxhn3pDKaWDI=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
}

