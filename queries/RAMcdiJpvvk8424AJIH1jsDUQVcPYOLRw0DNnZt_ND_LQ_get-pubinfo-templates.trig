@prefix np: <http://www.nanopub.org/nschema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix nt: <https://w3id.org/np/o/ntemplate/> .
@prefix npx: <http://purl.org/nanopub/x/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix orcid: <https://orcid.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:get-pubinfo-templates a <https://w3id.org/kpxl/grlc/grlc-query>;
    dct:description "Returns the basic info of all publication info templates.";
    dct:license <http://www.apache.org/licenses/LICENSE-2.0>;
    rdfs:label "Get pubinfo templates";
    <https://w3id.org/kpxl/grlc/endpoint> <https://w3id.org/np/l/nanopub-query-1.1/repo/type/45a89137e16d91eb7c7229b4e9033f49512604f94b65c7a9e3a093759293095b>;
    <https://w3id.org/kpxl/grlc/sparql> """prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix dct: <http://purl.org/dc/terms/>
prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>
prefix nt: <https://w3id.org/np/o/ntemplate/>

select ?np ?pubkey ?pubkeyhash ?date ?label ?creator where {
  graph npa:graph {
    ?np npa:hasValidSignatureForPublicKey ?pubkey .
    filter not exists { ?npx npx:invalidates ?np ; npa:hasValidSignatureForPublicKey ?pubkey . }
    ?np npa:hasValidSignatureForPublicKeyHash ?pubkeyhash .
    ?np npx:hasNanopubType nt:PubinfoTemplate .
    ?np dct:created ?date .
    ?np np:hasAssertion ?a .
    optional { ?np npx:signedBy ?creator . }
  }
  graph ?a {
    ?a rdfs:label ?label .
  }
} order by desc(?date)""" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

