@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:get-services a <https://w3id.org/kpxl/grlc/grlc-query>;
    dct:description "This query returns all nanopub services announced in nanopublications.";
    dct:license <http://www.apache.org/licenses/LICENSE-2.0>;
    rdfs:label "Get all nanopub services (simple view)";
    <https://w3id.org/kpxl/grlc/endpoint> <https://w3id.org/np/l/nanopub-query-1.1/repo/type/05603d3d4c5fea99f7a2622bfe7601cb519e2decf5147c9372518823c3cd975d>;
    <https://w3id.org/kpxl/grlc/sparql> """prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix dct: <http://purl.org/dc/terms/>
prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>

select ?service ?service_label ?serviceType ?np where {
  graph npa:graph {
    ?np npx:hasNanopubType npx:NanopubService .
    ?np npa:hasValidSignatureForPublicKeyHash ?pubkey .
    filter not exists { ?npx npx:invalidates ?np ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }
    optional { ?np dct:created ?date . }
    ?np np:hasAssertion ?a .
  }
  graph ?a {
    ?service a npx:NanopubService .
    ?service a ?serviceType .
    ?service rdfs:label ?service_label .
    filter(?serviceType != npx:NanopubService)
  }
} order by ?service_label""" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

