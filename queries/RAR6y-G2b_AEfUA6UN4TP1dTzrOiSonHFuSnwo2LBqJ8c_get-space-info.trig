    npx:hasSignature "mnneOt1ujicjaa2CQknqpILR1ZiTUKj1j31rPcdnunwy3lWPdPqVNvFJVmtNPlS1b8krS/MVy8CdZjDxfMbUVRt1yRCaKlwNeEWvFdX7MKrysKwKBBVf+/QmhgU+KpEuqlb9eg4jCaFBhh4ivB1ey+vdd546FczVnTSABCTA+G8=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
