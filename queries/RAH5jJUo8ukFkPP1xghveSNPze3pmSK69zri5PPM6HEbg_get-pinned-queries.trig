sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:get-pinned-queries a <https://w3id.org/kpxl/grlc/grlc-query>;
    dct:description "This query returns all pinned querie declarations for the given Space.";
    dct:license <http://www.apache.org/licenses/LICENSE-2.0>;
    rdfs:label "Get pinned queries";
    <https://w3id.org/kpxl/grlc/endpoint> <https://w3id.org/np/l/nanopub-query-1.1/repo/type/2f015fe8a76203b3802178d9104416bd39d2592618810fc070af54351971bed0>;
    <https://w3id.org/kpxl/grlc/sparql> """prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix dct: <http://purl.org/dc/terms/>
prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>
prefix gen: <https://w3id.org/kpxl/gen/terms/>

select ?query ?tag ?np ?pubkey ?date where {
  graph npa:graph {
    ?np npa:hasValidSignatureForPublicKeyHash ?pubkey .
    filter not exists { ?npx npx:invalidates ?np ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }
    ?np dct:created ?date .
    ?np np:hasAssertion ?a .
    optional { ?np rdfs:label ?label }
  }
  graph ?a {
    values ?_space_multi_iri {}
    ?_space_multi_iri gen:hasPinnedQuery ?query .
    optional { ?query gen:hasPinGroupTag ?tag . }
  }
} order by desc(?date)""" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

