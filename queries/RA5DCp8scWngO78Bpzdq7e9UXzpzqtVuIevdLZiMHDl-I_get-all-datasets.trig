sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:get-all-datasets a <https://w3id.org/kpxl/grlc/grlc-query>;
    dct:description "This query returns all datasets.";
    dct:license <http://www.apache.org/licenses/LICENSE-2.0>;
    rdfs:label "Get all datasets";
    <https://w3id.org/kpxl/grlc/endpoint> <https://w3id.org/np/l/nanopub-query-1.1/repo/full>;
    <https://w3id.org/kpxl/grlc/sparql> """PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX np: <http://www.nanopub.org/nschema#>
PREFIX npa: <http://purl.org/nanopub/admin/>
PREFIX npx: <http://purl.org/nanopub/x/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dct: <http://purl.org/dc/terms/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX schema: <https://schema.org/>

SELECT ?n1 ?label ?thing ?date ?funder where {
  GRAPH npa:graph {
    ?n1 npa:hasValidSignatureForPublicKey ?pubkey .
    filter not exists {
      ?np2 npx:invalidates ?n1 ;
            npa:hasValidSignatureForPublicKey ?pubkey .
    }
    ?n1 dct:created ?date .
    ?n1 np:hasAssertion ?a .
  } 
graph ?a {
?thing a <https://w3id.org/fair/ff/terms/Project> .
?thing rdfs:label ?label .
?thing schema:funder ?funder
  }
}""" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

