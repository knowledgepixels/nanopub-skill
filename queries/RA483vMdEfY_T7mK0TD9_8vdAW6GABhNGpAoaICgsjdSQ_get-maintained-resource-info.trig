    npx:hasSignature "X2KDP2t+aRNA96DmYy6xNNuOSpk8X5qcBSh3F9k6gN9lOhMsX/XXGakkbIBBlQnYAwZPiUWe+fKyHeBM+LA3Wxj6HDs8+4IGfDeXOzRfC4DVszsPl8fY5CpvEScamB+qpiARoA95KTurqQqFAEC/Tv1ZwMyxxl2tiwFKR8DE04g=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
}

