    npx:hasSignature "V+/bDJbvsFmJOBliCfvADW0592mLyVVALiSxUdr1v5QWiUe2qOKJJB2zes8ldYx3EclGxMlLJTew59gqbtC+mZy5EF7Cd7Y49RhBwqWk5F1Rn/oJ6SKmNQOI1V/PprbQuJvXzYtAMEC+25skfUPoaMJX16eyJdT4DgWmj/RjpOw=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
}

