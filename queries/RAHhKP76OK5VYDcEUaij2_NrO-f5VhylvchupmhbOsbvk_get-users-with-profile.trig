    npx:hasSignature "bYmBDoF2yN4bYvFZ4cqnWvOB3Z6KC+yrNdsmu+pW01HNlI5BxqAvMoP4e8woeRbQRD8MPeKb3GN0L6mCiUmKXULwfP/2yuxDSSVkxnpIgfbH/uZ2x1trV/D/AuTs4AusUD4Es1xHWe4UHlRfKBwgYwY4i0JQaJ34D30EsA5losQ=";
