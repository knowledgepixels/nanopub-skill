@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix orcid: <https://orcid.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:get-all-us a <https://w3id.org/kpxl/grlc/grlc-query>;
    dct:description "This query returns all user stories.";
    dct:license <http://www.apache.org/licenses/LICENSE-2.0>;
    rdfs:label "Get user stories";
    <https://w3id.org/kpxl/grlc/endpoint> <https://w3id.org/np/l/nanopub-query-1.1/repo/full>;
    <https://w3id.org/kpxl/grlc/sparql> """PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dct: <http://purl.org/dc/terms/>
PREFIX np: <http://www.nanopub.org/nschema#>
PREFIX npa: <http://purl.org/nanopub/admin/>
PREFIX npx: <http://purl.org/nanopub/x/>
PREFIX fff: <https://w3id.org/fff/req/>

SELECT DISTINCT ?np ?date ?label ?userStory
WHERE {

  ## Info about this repo
  npa:thisRepo ?repoPred ?repoObj .

  ## Search for valid nanopublications
  GRAPH npa:graph {
    ?np npa:hasValidSignatureForPublicKey ?pubkey .
    FILTER NOT EXISTS {
      ?invalid npx:invalidates ?np ;
               npa:hasValidSignatureForPublicKey ?pubkey .
    }
    ?np dct:created ?date .
    ?np np:hasAssertion ?a .
    OPTIONAL { ?np rdfs:label ?label }
  }

  ## Look inside the assertion graph
  GRAPH ?a {
    ?userStory a fff:User-Story .
  }
}
ORDER BY DESC(?date)""" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

