    npx:hasSignature "pk0C5X4uzRwEtg7FfgarsgXQsl/TxjWFdCRAIrlJCovjF/p+w9z7G+vy06sYEBVEozE+7sIrxFk2UTdGVa0tkxSbo7mtPR6K/CtSWjiERIBWUtC112LD43dXTacPPNA4MxzpGYVI/90DdrFOM/pFYcehdbFW9aUFNE04F0kSfKk=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
}

