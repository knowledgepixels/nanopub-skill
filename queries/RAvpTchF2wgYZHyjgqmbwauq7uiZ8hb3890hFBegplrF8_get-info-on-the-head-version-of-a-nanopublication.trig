    npx:hasSignature "s7gvG7puhpSmtzfKQZeydpu6rI7luJ9WyZhewBRKbgE7fpJ6RJkOcbWhdgvUX5aev2JYd6gI/R3g7Lqem1rzRxOt7tRfTaRqmlotkLqIV9TqKZUaSWRnRw64UaZ8MH6/Yj/lYwf78FUvxHJ6AGW3sDHpuw8CzT+tKjFz2dEpD7o=";
