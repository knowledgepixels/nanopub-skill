    npx:hasSignature "fRpbbe7tfNY/UkGvDMrpQc7+gce61XhCA/kztECBY+Mdh9aVTpoBrwUzg/J93BP7Tjvh4RZUMcgSu7WtmLB6VNkGnCbeDwRFCf1zlKG3pp77Ro4zhefn3ta8ztufq9huHam+gBF7dGcJI5ZeKgEgjW8B3U/938OOatVhTkVxXxg=";
