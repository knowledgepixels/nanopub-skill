    npx:hasSignature "HQoMqcCp3x262LMq9Wmg92q7jDjYAIrQ8xZliXyAAsDCkKAtD8cvp+7367qxAgMks+4NHuq/Q1lQgwRA09YwuCF4KeV9Adc82i2oAC7tIt13AAckwN5EtTmzRnPkGEAuYOaig1Q5Z5V5ydSFwIzC9azSs2Htvyk5S5m9s4A6zjY=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
}

