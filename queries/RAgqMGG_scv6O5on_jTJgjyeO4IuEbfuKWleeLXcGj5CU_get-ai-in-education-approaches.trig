sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:get-ai-in-edu-approaches a <https://w3id.org/kpxl/grlc/grlc-query>;
    dct:description "This query returns all approaches in AI for Education";
    dct:license <http://www.apache.org/licenses/LICENSE-2.0>;
    rdfs:label "Get AI in Education approaches";
    <https://w3id.org/kpxl/grlc/endpoint> <https://w3id.org/np/l/nanopub-query-1.1/repo/type/036e2dfb15559f2989125bef80bd2f8c4e74a37cbc6d1a96cd5fd08e5b7956d4>;
    <https://w3id.org/kpxl/grlc/sparql> """prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix dct: <http://purl.org/dc/terms/>
prefix np: <http://www.nanopub.org/nschema#>
prefix npa: <http://purl.org/nanopub/admin/>
prefix npx: <http://purl.org/nanopub/x/>

select ?approach ?approach_label ?class ?reference ?reference_label ?creator ?date ?np (\"^\" as ?np_label) where {
  graph npa:graph {
    ?np npx:hasNanopubType <https://w3id.org/spaces/AI-in-education/r/terms/AI-in-Education-approach> .
    ?np npa:hasValidSignatureForPublicKeyHash ?pubkey .
    filter not exists { ?npx npx:invalidates ?np ; npa:hasValidSignatureForPublicKeyHash ?pubkey . }
    ?np dct:created ?date .
    ?np npx:signedBy ?creator .
    ?np np:hasAssertion ?a .
    ?np npx:introduces ?approach .
  }
  graph ?a {
    ?approach a <https://w3id.org/spaces/AI-in-education/r/terms/AI-in-Education-approach> .
    optional {
      ?approach a ?class .
      filter(?class != <https://w3id.org/spaces/AI-in-education/r/terms/AI-in-Education-approach>)
    }
    ?approach rdfs:label ?approach_label .
    ?approach dct:source ?reference .
    ?reference rdfs:label ?reference_label .
  }
}""" .
}

