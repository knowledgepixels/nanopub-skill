    npx:hasSignature "np67HhXISvZNqDN2ueg0TmL0wmwBqWr5xRFqkzY6tjxvZVwxSCSmZhLUVRD0KdNJEc66l1Sn9FcxmivJy/7gpOg+JtL5LlD5gwfmM7Z5YoI1Fj7sXT1KN3wmUuMHJp4IbQoi3Diz390ff9Of1ti586gbD29RXZWpHxWHLTgKngg=";
    npx:hasSignatureTarget this:;
