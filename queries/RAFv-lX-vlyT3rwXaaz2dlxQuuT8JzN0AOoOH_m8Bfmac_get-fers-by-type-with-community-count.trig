    npx:hasSignature "tM/V4/oXEcvas6GRUUEMSUkp5Gs9AcXMpMszxL7Yr7u5R4AvUEz8FdE1nVDEeOeapXL+CpNU6MhJlGQkwZ7RJnd3XCtR+SG/8D4RiLIIcdHTfgqiwzdSe7f1UA3OBUdJn81m/DLP7d/Ic1G1OujW9LyeugXfK+TQ6o2hAYOfNHU=";
