sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  rdf:type rdfs:label "is a" .
  
  rdfs:comment rdfs:label "has description" .
  
  rdfs:label rdfs:label "has title" .
  
  <https://w3id.org/fair/fip/terms/has-description-source> rdfs:label "has source" .
  
  <https://w3id.org/fff/req/digital-object-type> rdfs:label "has digital object type" .
  
  <https://w3id.org/fff/req/fair-assessment> rdfs:label "has FAIR assessment" .
  
  <https://w3id.org/fff/req/fairification> rdfs:label "has FAIRification plan" .
  
  <https://w3id.org/fff/req/has-fip> rdfs:label "has FAIR Implementation Plan" .
  
  <https://w3id.org/fff/req/has-variable> rdfs:label "has variable" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Template for analysing a Digital Object";
    rdfs:label "Anaylsing a Digital Object";
    nt:hasRequiredPubinfoElement ns1:RA_R5w4lZ-6xuZyylG8qSlMhmWBaTE41-zlhiBVUQblCc;
    nt:hasStatement sub:st01, sub:st02, sub:st03, sub:st03a, sub:st04, sub:st04a, sub:st05,
      sub:st06, sub:st08, sub:st09, sub:st10;
    nt:hasTag "FAIR" .
  
  sub:assessment a nt:GuidedChoicePlaceholder;
    rdfs:label "FAIR Assessment report" .
  
  sub:contact a nt:AgentPlaceholder;
    rdfs:label "ORCID of contact point" .
  
  sub:description a nt:LiteralPlaceholder;
    rdfs:label "description" .
  
  sub:do a nt:IntroducedResource, nt:LocalResource, nt:UriPlaceholder;
    rdfs:label "digital object analysis" .
  
  sub:fip a nt:ExternalUriPlaceholder;
    rdfs:label "identifier of the FAIR Implementation Profile" .
  
  sub:name a nt:LiteralPlaceholder;
    rdfs:label "title" .
  
  sub:pid a nt:ExternalUriPlaceholder;
    rdfs:label "persistent identifier of a representative digital object" .
  
  sub:plan a nt:ExternalUriPlaceholder;
    rdfs:label "action plan" .
  
  sub:source a nt:ExternalUriPlaceholder;
    rdfs:label "URI to source" .
  
  sub:st01 rdf:object <https://w3id.org/fff/req/Digital-Object-Analysis>;
    rdf:predicate rdf:type;
    rdf:subject sub:do .
  
  sub:st02 rdf:object sub:name;
    rdf:predicate rdfs:label;
    rdf:subject sub:do .
  
  sub:st03 rdf:object sub:description;
    rdf:predicate rdfs:comment;
    rdf:subject sub:do .
  
  sub:st03a a nt:RepeatableStatement;
    rdf:object sub:source;
    rdf:predicate <https://w3id.org/fair/fip/terms/has-description-source>;
    rdf:subject sub:do .
  
  sub:st04 a nt:RepeatableStatement;
    rdf:object sub:pid;
    rdf:predicate <https://schema.org/url>;
    rdf:subject sub:do .
  
  sub:st04a a nt:OptionalStatement;
    rdf:object sub:contact;
    rdf:predicate <https://www.w3.org/ns/dcat#contactPoint>;
    rdf:subject sub:do .
  
  sub:st05 rdf:object sub:type;
    rdf:predicate <https://w3id.org/fff/req/digital-object-type>;
    rdf:subject sub:do .
  
  sub:st06 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:variable;
    rdf:predicate <https://w3id.org/fff/req/has-variable>;
    rdf:subject sub:do .
  
  sub:st08 rdf:object sub:fip;
    rdf:predicate <https://w3id.org/fff/req/has-fip>;
    rdf:subject sub:do .
  
  sub:st09 rdf:object sub:assessment;
    rdf:predicate <https://w3id.org/fff/req/fair-assessment>;
    rdf:subject sub:do .
  
  sub:st10 rdf:object sub:plan;
    rdf:predicate <https://w3id.org/fff/req/fairification>;
    rdf:subject sub:do .
  
  sub:type a nt:GuidedChoicePlaceholder, nt:LiteralPlaceholder;
    rdfs:label "digital object type";
    nt:possibleValuesFrom ns1:RACXDZHEowTYDAzZvdmD0qIGpXZwY5ghMRBBlt6N8Iu5s .
  
  sub:variable rdfs:label "URI to FAIR variable" .
  
  <https://www.w3.org/ns/dcat#contactPoint> rdfs:label "has contact point" .
}

