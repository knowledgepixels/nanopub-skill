sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  dct:identifier rdfs:label "has identifier" .
  
  rdfs:comment rdfs:label "has description" .
  
  rdfs:label rdfs:label "has label" .
  
  <https://w3id.org/fair/fip/terms/has-research-domain> rdfs:label "has research domain" .
  
  sub:CS a nt:IntroducedResource, nt:LocalResource, nt:UriPlaceholder;
    rdfs:label "Case Study" .
  
  sub:Domain a nt:RestrictedChoicePlaceholder;
    nt:possibleValuesFrom ns1:RACXDZHEowTYDAzZvdmD0qIGpXZwY5ghMRBBlt6N8Iu5s .
  
  sub:LeadInstitutionName a nt:LiteralPlaceholder;
    rdfs:label "Lead Institution Name" .
  
  sub:ORCID a nt:ExternalUriPlaceholder .
  
  sub:OtherPartners a nt:LiteralPlaceholder;
    rdfs:label "Other Partners" .
  
  sub:ROR a nt:ExternalUriPlaceholder .
  
  sub:assertion a nt:AssertionTemplate, nt:UnlistedTemplate;
    dct:description "Template for defining a Case study";
    rdfs:label "Practice CS template M4M course 1";
    nt:hasStatement sub:st1, sub:st10, sub:st11, sub:st2, sub:st9 .
  
  sub:comment a nt:LiteralPlaceholder .
  
  sub:name a nt:LiteralPlaceholder .
  
  sub:st1 rdf:object sub:name;
    rdf:predicate rdfs:label;
    rdf:subject sub:CS .
  
  sub:st10 a nt:GroupedStatement;
    nt:hasStatement sub:st3, sub:st4, sub:st5 .
  
  sub:st11 a nt:GroupedStatement, nt:OptionalStatement, nt:RepeatableStatement;
    nt:hasStatement sub:st6, sub:st7, sub:st8 .
  
  sub:st2 rdf:object sub:comment;
    rdf:predicate rdfs:comment;
    rdf:subject sub:CS .
  
  sub:st3 rdf:object sub:LeadInstitutionName;
    rdf:predicate rdfs:label;
    rdf:subject sub:CS .
  
  sub:st4 a nt:OptionalStatement;
    rdf:object sub:ROR;
    rdf:predicate dct:identifier;
    rdf:subject sub:CS .
  
  sub:st5 rdf:object sub:ORCID;
    rdf:predicate <https://www.w3.org/ns/dcat#contactPoint>;
    rdf:subject sub:CS .
  
  sub:st6 rdf:object sub:OtherPartners;
    rdf:predicate rdfs:label;
    rdf:subject sub:CS .
  
  sub:st7 a nt:OptionalStatement;
    rdf:object sub:ROR;
    rdf:predicate dct:identifier;
    rdf:subject sub:CS .
  
  sub:st8 rdf:object sub:ORCID;
    rdf:predicate <https://www.w3.org/ns/dcat#contactPoint>;
    rdf:subject sub:CS .
  
  sub:st9 a nt:RepeatableStatement;
    rdf:object sub:Domain;
    rdf:predicate <https://w3id.org/fair/fip/terms/has-research-domain>;
    rdf:subject sub:CS .
  
  <https://www.w3.org/ns/dcat#contactPoint> rdfs:label "has contact point" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo <https://ror.org/056j50v04> .
}

