    rdf:subject sub:dataset .
  
  sub:st07c a rdf:Statement;
    rdf:object <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C64357>;
    rdf:predicate nt:hasStatement;
    rdf:subject sub:dataset .
  
  sub:st07d a rdf:Statement;
    rdf:object <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C64356>;
    rdf:predicate nt:hasStatement;
    rdf:subject sub:dataset .
  
  sub:st08 a rdf:Statement;
