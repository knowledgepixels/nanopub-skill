  orcid:0000-0002-1267-0234 foaf:name "Tobias Kuhn" .
  
  orcid:0000-0002-1784-2920 foaf:name "Anne Fouilloux" .
  
  this: dct:created "2026-04-02T14:39:20.508Z"^^xsd:dateTime;
