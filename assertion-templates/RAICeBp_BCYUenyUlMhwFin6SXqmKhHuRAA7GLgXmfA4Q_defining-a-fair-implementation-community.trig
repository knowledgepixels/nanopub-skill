@prefix this: <https://w3id.org/np/RAICeBp_BCYUenyUlMhwFin6SXqmKhHuRAA7GLgXmfA4Q> .
@prefix sub: <https://w3id.org/np/RAICeBp_BCYUenyUlMhwFin6SXqmKhHuRAA7GLgXmfA4Q#> .
@prefix np: <http://www.nanopub.org/nschema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix nt: <https://w3id.org/np/o/ntemplate/> .
@prefix npx: <http://purl.org/nanopub/x/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix orcid: <https://orcid.org/> .
@prefix ns1: <http://purl.org/np/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  dct:isPartOf rdfs:label "is a sub-community of" .
  
  rdf:type rdfs:label "is a" .
  
  rdfs:comment rdfs:label "has the description" .
  
  rdfs:label rdfs:label "is called" .
  
  rdfs:seeAlso rdfs:label "has the website" .
  
  <http://www.w3.org/2004/02/skos/core#closeMatch> rdfs:label "can in some situations be considered the same as" .
  
  <http://www.w3.org/2004/02/skos/core#exactMatch> rdfs:label "is (almost) exactly the same as" .
  
  <http://www.w3.org/2004/02/skos/core#relatedMatch> rdfs:label "is related to" .
  
  <https://w3id.org/fair/fip/terms/Emerging-Community> rdfs:label "emerging community" .
  
  <https://w3id.org/fair/fip/terms/FAIR-Implementation-Community> rdfs:label "FAIR implementation community" .
  
  <https://w3id.org/fair/fip/terms/Mature-Community> rdfs:label "mature community" .
  
  <https://w3id.org/fair/fip/terms/has-research-domain> rdfs:label "has the research domain" .
  
  sub:MaturityType a nt:RestrictedChoicePlaceholder;
    rdfs:label "choose the maturity type";
    nt:possibleValue <https://w3id.org/fair/fip/terms/Emerging-Community>, <https://w3id.org/fair/fip/terms/Mature-Community> .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Template for defining a community of practice aiming at implementing the FAIR principles.";
    rdfs:label "Defining a FAIR implementation community";
    nt:hasStatement sub:st0, sub:st1, sub:st2, sub:st2a, sub:st2b, sub:st3, sub:st4, sub:st7,
      sub:st9;
    nt:hasTag "FAIR";
    nt:hasTargetNanopubType <https://w3id.org/fair/fip/terms/FAIR-Supporting-Resource> .
  
  sub:comment a nt:LiteralPlaceholder;
    rdfs:label "description of the community in one sentence" .
  
  sub:community a nt:IntroducedResource, nt:LocalResource, nt:UriPlaceholder;
    rdfs:label "short name, used as URI suffix" .
  
  sub:domain a nt:RestrictedChoicePlaceholder;
    nt:possibleValuesFrom ns1:RACXDZHEowTYDAzZvdmD0qIGpXZwY5ghMRBBlt6N8Iu5s .
  
  sub:mappedCommunity a nt:ExternalUriPlaceholder;
    rdfs:label "the identifier of the related community description" .
  
  sub:mappingPredicate a nt:RestrictedChoicePlaceholder;
    nt:possibleValue <http://www.w3.org/2004/02/skos/core#closeMatch>, <http://www.w3.org/2004/02/skos/core#exactMatch>,
      <http://www.w3.org/2004/02/skos/core#relatedMatch> .
  
  sub:name a nt:LiteralPlaceholder;
    rdfs:label "the name of your community" .
  
  sub:source a nt:ExternalUriPlaceholder;
    rdfs:label "source of description" .
  
  sub:st0 rdf:object <https://w3id.org/fair/fip/terms/FAIR-Implementation-Community>;
    rdf:predicate rdf:type;
    rdf:subject sub:community .
  
  sub:st1 rdf:object sub:name;
    rdf:predicate rdfs:label;
    rdf:subject sub:community .
  
  sub:st2 rdf:object sub:comment;
    rdf:predicate rdfs:comment;
    rdf:subject sub:community .
  
  sub:st2a a nt:OptionalStatement;
    rdf:object sub:source;
    rdf:predicate <https://w3id.org/fair/fip/terms/has-description-source>;
    rdf:subject sub:community .
  
  sub:st2b a nt:OptionalStatement;
    rdf:object sub:MaturityType;
    rdf:predicate rdf:type;
    rdf:subject sub:community .
  
  sub:st3 a nt:OptionalStatement;
    rdf:object sub:website;
    rdf:predicate rdfs:seeAlso;
    rdf:subject sub:community .
  
  sub:st4 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:domain;
    rdf:predicate <https://w3id.org/fair/fip/terms/has-research-domain>;
    rdf:subject sub:community .
  
  sub:st7 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:supercommunity;
    rdf:predicate dct:isPartOf;
    rdf:subject sub:community .
  
  sub:st9 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:mappedCommunity;
    rdf:predicate sub:mappingPredicate;
    rdf:subject sub:community .
  
  sub:supercommunity a nt:GuidedChoicePlaceholder;
    rdfs:label "the larger community";
    nt:possibleValuesFromApi "http://purl.org/nanopub/api/find_signed_things?type=https%3A%2F%2Fw3id.org%2Ffair%2Ffip%2Fterms%2FFAIR-Implementation-Community&searchterm=" .
  
  sub:website a nt:ExternalUriPlaceholder;
    rdfs:label "a link to the community's website" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo <https://ror.org/056j50v04> .
}

