sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  <https://schema.org/image> rdfs:label "has the profile picture" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "This template is used to define the profile picture of a User";
    rdfs:label "Define the profile picture of a User";
    nt:hasStatement sub:st .
  
  sub:imageUrl a nt:ExternalUriPlaceholder .
  
  sub:st rdf:object sub:imageUrl;
    rdf:predicate <https://schema.org/image>;
    rdf:subject sub:user .
  
  sub:user a nt:AgentPlaceholder .
}

