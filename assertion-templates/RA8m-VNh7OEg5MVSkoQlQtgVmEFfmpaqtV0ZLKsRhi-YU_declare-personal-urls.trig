sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  rdfs:label rdfs:label "has the label" .
  
  rdfs:seeAlso rdfs:label "has the personal URL" .
  
  sub:assertion a nt:AssertionTemplate;
    rdfs:label "Declare personal URLs";
    nt:hasStatement sub:st1, sub:st2;
    nt:hasTargetNanopubType rdfs:seeAlso .
  
  sub:label a nt:LiteralPlaceholder;
    rdfs:label "label for the URL (e.g. \"my website\")" .
  
  sub:personalUrl a nt:ExternalUriPlaceholder;
    rdfs:label "URL" .
  
  sub:st1 rdf:object sub:personalUrl;
    rdf:predicate rdfs:seeAlso;
    rdf:subject nt:CREATOR .
  
  sub:st2 rdf:object sub:label;
    rdf:predicate rdfs:label;
    rdf:subject sub:personalUrl .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

