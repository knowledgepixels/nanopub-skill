    rdf:subject <https://example.org/subj> .
  
  sub:st4 rdf:object sub:literal4;
    rdf:predicate <https://example.org/pred4>;
    rdf:subject <https://example.org/subj> .
  
  sub:st5 rdf:object sub:literal5;
    rdf:predicate <https://example.org/pred5>;
    rdf:subject <https://example.org/subj> .
}

