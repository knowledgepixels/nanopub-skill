sub:assertion {
  sub:assertion a nt:AssertionTemplate, nt:UnlistedTemplate;
    dct:description "Just for testing literal datatypes / language tags.";
    rdfs:label "Literal datatype / language tag testing";
    nt:hasStatement sub:st1, sub:st2, sub:st3, sub:st4, sub:st5 .
  
  sub:literal1 a nt:LiteralPlaceholder;
    nt:hasDatatype <https://example.org/myOwnDatatype> .
  
  sub:literal2 a nt:LiteralPlaceholder;
    nt:hasLanguageTag "de" .
  
  sub:literal3 a nt:LongLiteralPlaceholder;
    nt:hasDatatype xsd:int .
  
  sub:literal4 a nt:LongLiteralPlaceholder;
    nt:hasLanguageTag "de-ch" .
  
  sub:literal5 a nt:LiteralPlaceholder .
  
  sub:st1 rdf:object sub:literal1;
    rdf:predicate <https://example.org/pred1>;
    rdf:subject <https://example.org/subj> .
  
  sub:st2 rdf:object sub:literal2;
    rdf:predicate <https://example.org/pred2>;
    rdf:subject <https://example.org/subj> .
  
  sub:st3 rdf:object sub:literal3;
