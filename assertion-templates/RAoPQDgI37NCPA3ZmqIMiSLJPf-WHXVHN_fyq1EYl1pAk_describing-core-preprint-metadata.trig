    npx:hasSignature "lyU2mv8ueHYsaXpZ9vrA91iSNr2hU4AwV2gfMUt6Q4i9TpZ43JF1EjJDiIDbBxzNVq02upt9PVb1ib9f5gQRxYQhlxpqlWvF+W90F0yQNSdr0vLItZzGKdNs8B+ow/7U6nSje4s1/bU2b6cDvtL7iGYxu0md0Yn640o7ZhIK0iI=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
}

