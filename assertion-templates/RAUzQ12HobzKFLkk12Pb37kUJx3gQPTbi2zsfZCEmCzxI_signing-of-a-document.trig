sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  npx:signsDocument rdfs:label "sign the document" .
  
  sub:assertion a nt:AssertionTemplate;
    rdfs:label "Signing of a document";
    nt:hasNanopubLabelPattern "Signing of ${document}";
    nt:hasStatement sub:st1;
    nt:hasTag "Meta" .
  
  sub:document a nt:UriPlaceholder;
    rdfs:label "URI of the document" .
  
  sub:st1 rdf:object sub:document;
    rdf:predicate npx:signsDocument;
    rdf:subject nt:CREATOR .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

