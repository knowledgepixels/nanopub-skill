sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  <http://purl.obolibrary.org/obo/SEPIO_0000101> rdfs:label "contradicts" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Such a nanopublication expresses a contradiction.";
    rdfs:label "Expressing a contradiction";
    nt:hasStatement sub:st1;
    nt:hasTag "Contradiction" .
  
  sub:st1 rdf:object sub:statement2;
    rdf:predicate <http://purl.obolibrary.org/obo/SEPIO_0000101>;
    rdf:subject sub:statement1 .
  
  sub:statement1 a nt:ExternalUriPlaceholder;
    rdfs:label "URI of the initial statement that is contradicted by another statement" .
  
  sub:statement2 a nt:ExternalUriPlaceholder;
    rdfs:label "URI of the statement that contradicts the initial statement" .
}

sub:provenance {
