    rdf:subject sub:infrastructure .
  
  sub:stakeholder-engagement a nt:LongLiteralPlaceholder;
    rdfs:label "How are you engaging stakeholders in strategy development and decisions?" .
  
  sub:standard-implemented a nt:UriPlaceholder;
    rdfs:label "Standards, Schema, Persistent Identifiers Used" .
  
