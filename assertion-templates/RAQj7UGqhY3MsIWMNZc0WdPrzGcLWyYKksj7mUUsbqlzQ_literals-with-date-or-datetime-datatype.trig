sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:assertion a nt:AssertionTemplate, nt:UnlistedTemplate;
    dct:description "Just for testing literals with date or dateTime datatype";
    rdfs:label "Literals with date or dateTime datatype";
    nt:hasStatement sub:st1, sub:st5 .
  
  sub:literal1 a nt:LiteralPlaceholder;
    nt:hasDatatype xsd:dateTime .
  
  sub:st1 rdf:object sub:literal1;
    rdf:predicate <https://example.org/pred1>;
    rdf:subject <https://example.org/subj> .
  
  sub:st5 rdf:object sub:literal1;
    rdf:predicate <https://example.org/pred5>;
    rdf:subject <https://example.org/subj> .
}

