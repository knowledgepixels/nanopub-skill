    npx:hasSignature "U512lZQrrYNhyXjx+ZzmsJFPIKaXLwBRwzYN/0ehy39P4NoY54ddLINat2KHuJW4E+a4I/hDIHpZ5P4UxGWTYFh9Krr458qzclRtyWsOJDULBu+7Yb36l7uBIoTWeTmkHQA79wMEzIThQ4DcU8fKnOfgimHfg6ZUN/ijx8S4Vrw=";
    npx:hasSignatureTarget this:;
    npx:signedBy orcid:0000-0002-1267-0234 .
}

