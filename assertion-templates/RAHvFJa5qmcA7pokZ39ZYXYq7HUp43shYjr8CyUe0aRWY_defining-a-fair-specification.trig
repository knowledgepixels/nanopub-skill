@prefix this: <https://w3id.org/np/RAHvFJa5qmcA7pokZ39ZYXYq7HUp43shYjr8CyUe0aRWY> .
@prefix sub: <https://w3id.org/np/RAHvFJa5qmcA7pokZ39ZYXYq7HUp43shYjr8CyUe0aRWY/> .
@prefix np: <http://www.nanopub.org/nschema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix nt: <https://w3id.org/np/o/ntemplate/> .
@prefix npx: <http://purl.org/nanopub/x/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix orcid: <https://orcid.org/> .
@prefix ns1: <http://purl.org/np/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  dct:creator rdfs:label "created by" .
  
  <http://schema.org/url> rdfs:label "is accessible via" .
  
  rdf:type rdfs:label "is a" .
  
  rdfs:comment rdfs:label "has the description" .
  
  rdfs:label rdfs:label "is called" .
  
  rdfs:seeAlso rdfs:label "is further described by" .
  
  <http://www.w3.org/2004/02/skos/core#broadMatch> rdfs:label "has parent resource" .
  
  <http://www.w3.org/2004/02/skos/core#closeMatch> rdfs:label "can in some situations be considered the same as" .
  
  <http://www.w3.org/2004/02/skos/core#exactMatch> rdfs:label "is (almost) exactly the same as" .
  
  <http://www.w3.org/2004/02/skos/core#relatedMatch> rdfs:label "is related to" .
  
  <https://schema.org/version> rdfs:label "has version" .
  
  <https://w3id.org/fair/fip/terms/Available-FAIR-Enabling-Resource> rdfs:label "available FAIR Enabling Resource" .
  
  <https://w3id.org/fair/fip/terms/Communication-protocol> rdfs:label "communication protocol" .
  
  <https://w3id.org/fair/fip/terms/FAIR-Enabling-Resource-to-be-Developed> rdfs:label
      "FAIR Enabling Resource to be developed" .
  
  <https://w3id.org/fair/fip/terms/Knowledge-representation-language> rdfs:label "knowledge representation language" .
  
  <https://w3id.org/fair/fip/terms/Metadata-data-linking-schema> rdfs:label "metadata-data linking schema" .
  
  <https://w3id.org/fair/fip/terms/Metadata-schema> rdfs:label "metadata schema" .
  
  <https://w3id.org/fair/fip/terms/Provenance-model> rdfs:label "provenance model" .
  
  <https://w3id.org/fair/fip/terms/Semantic-model> rdfs:label "semantic model" .
  
  <https://w3id.org/fair/fip/terms/Structured-vocabulary> rdfs:label "structured vocabulary" .
  
  <https://w3id.org/fair/fip/terms/has-data-usage-license> rdfs:label "has data usage license" .
  
  <https://w3id.org/fair/fip/terms/implements> rdfs:label "implements" .
  
  <https://w3id.org/fair/fip/terms/registered-on> rdfs:label "registered on" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Template for defining a FAIR specification for the following subtypes: metadata schema, metadata-data linking schema, communication protocol, knowledge representation language, structured vocabulary, semantic model and provenance model.";
    rdfs:label "Defining a FAIR Specification";
    nt:hasRequiredPubinfoElement ns1:RA_R5w4lZ-6xuZyylG8qSlMhmWBaTE41-zlhiBVUQblCc;
    nt:hasStatement sub:st02, sub:st1, sub:st2, sub:st2a, sub:st3, sub:st3a, sub:st4,
      sub:st4a, sub:st5, sub:st5a, sub:st6, sub:st6b, sub:st6c, sub:st6d, sub:st7;
    nt:hasTag "FAIR";
    nt:hasTargetNanopubType <https://w3id.org/fair/fip/terms/FAIR-Enabling-Resource>,
      <https://w3id.org/fair/fip/terms/FAIR-Supporting-Resource> .
  
  sub:comment a nt:LiteralPlaceholder;
    rdfs:label "description of the resource" .
  
  sub:creator a nt:GuidedChoicePlaceholder;
    rdfs:label "FAIR Implementation Community that created the resource";
    nt:possibleValuesFromApi "http://purl.org/nanopub/api/find_signed_things?type=https%3A%2F%2Fw3id.org%2Ffair%2Ffip%2Fterms%2FFAIR-Implementation-Community&searchterm=" .
  
  sub:dul a nt:GuidedChoicePlaceholder;
    rdfs:label "data usage license";
    nt:possibleValuesFromApi "http://purl.org/nanopub/api/find_signed_things?type=https%3A%2F%2Fw3id.org%2Ffair%2Ffip%2Fterms%2FData-usage-license&searchterm=" .
  
  sub:mappedResource a nt:ExternalUriPlaceholder;
    rdfs:label "the identifier of the related resource" .
  
  sub:mappingPredicate a nt:RestrictedChoicePlaceholder;
    rdfs:label "choose the relation type";
    nt:possibleValue <http://www.w3.org/2004/02/skos/core#closeMatch>, <http://www.w3.org/2004/02/skos/core#exactMatch>,
      <http://www.w3.org/2004/02/skos/core#relatedMatch> .
  
  sub:name a nt:LiteralPlaceholder;
    rdfs:label "the name of the resource" .
  
  sub:registry a nt:GuidedChoicePlaceholder;
    rdfs:label "choose the registry";
    nt:possibleValuesFromApi "http://purl.org/nanopub/api/find_signed_things?type=https%3A%2F%2Fw3id.org%2Ffair%2Ffip%2Fterms%2FRegistry&searchterm=" .
  
  sub:resource a nt:IntroducedResource, nt:LocalResource, nt:UriPlaceholder;
    rdfs:label "short name, used as URI suffix" .
  
  sub:resource-type1 a nt:RestrictedChoicePlaceholder;
    rdfs:label "choose resource availability";
    nt:possibleValue <https://w3id.org/fair/fip/terms/Available-FAIR-Enabling-Resource>,
      <https://w3id.org/fair/fip/terms/FAIR-Enabling-Resource-to-be-Developed> .
  
  sub:resource-type2 a nt:RestrictedChoicePlaceholder;
    rdfs:label "choose resource type(s)";
    nt:possibleValue <https://w3id.org/fair/fip/terms/Communication-protocol>, <https://w3id.org/fair/fip/terms/Knowledge-representation-language>,
      <https://w3id.org/fair/fip/terms/Metadata-data-linking-schema>, <https://w3id.org/fair/fip/terms/Metadata-schema>,
      <https://w3id.org/fair/fip/terms/Provenance-model>, <https://w3id.org/fair/fip/terms/Semantic-model>,
      <https://w3id.org/fair/fip/terms/Structured-vocabulary> .
  
  sub:source a nt:ExternalUriPlaceholder;
    rdfs:label "source of description" .
  
  sub:specification a nt:GuidedChoicePlaceholder;
    rdfs:label "specification that this resource implements";
    nt:possibleValuesFromApi "https://w3id.org/np/l/nanopub-query-1.1/api/RAB_utnJ83p9BqEo3Ndw5YWDrM0jP1UH1VA6AkQh7Yrow/find-fair-specifications?query=" .
  
  sub:st02 rdf:object <https://w3id.org/fair/fip/terms/FAIR-Specification>;
    rdf:predicate rdf:type;
    rdf:subject sub:resource .
  
  sub:st1 rdf:object sub:name;
    rdf:predicate rdfs:label;
    rdf:subject sub:resource .
  
  sub:st2 rdf:object sub:comment;
    rdf:predicate rdfs:comment;
    rdf:subject sub:resource .
  
  sub:st2a a nt:OptionalStatement;
    rdf:object sub:source;
    rdf:predicate <https://w3id.org/fair/fip/terms/has-description-source>;
    rdf:subject sub:resource .
  
  sub:st3 rdf:object sub:resource-type1;
    rdf:predicate rdf:type;
    rdf:subject sub:resource .
  
  sub:st3a a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:resource-type2;
    rdf:predicate rdf:type;
    rdf:subject sub:resource .
  
  sub:st4 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:creator;
    rdf:predicate dct:creator;
    rdf:subject sub:resource .
  
  sub:st4a a nt:OptionalStatement;
    rdf:object sub:version;
    rdf:predicate <https://schema.org/version>;
    rdf:subject sub:resource .
  
  sub:st5 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:registry;
    rdf:predicate <https://w3id.org/fair/fip/terms/registered-on>;
    rdf:subject sub:resource .
  
  sub:st5a a nt:OptionalStatement;
    rdf:object sub:dul;
    rdf:predicate <https://w3id.org/fair/fip/terms/has-data-usage-license>;
    rdf:subject sub:resource .
  
  sub:st6 a nt:OptionalStatement;
    rdf:object sub:website;
    rdf:predicate rdfs:seeAlso;
    rdf:subject sub:resource .
  
  sub:st6b a nt:OptionalStatement;
    rdf:object sub:url;
    rdf:predicate <http://schema.org/url>;
    rdf:subject sub:resource .
  
  sub:st6c a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:specification;
    rdf:predicate <https://w3id.org/fair/fip/terms/implements>;
    rdf:subject sub:resource .
  
  sub:st6d a nt:OptionalStatement;
    rdf:object sub:specification;
    rdf:predicate <http://www.w3.org/2004/02/skos/core#broadMatch>;
    rdf:subject sub:resource .
  
  sub:st7 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:mappedResource;
    rdf:predicate sub:mappingPredicate;
    rdf:subject sub:resource .
  
  sub:url a nt:ExternalUriPlaceholder;
    rdfs:label "URL" .
  
  sub:version a nt:LiteralPlaceholder;
    rdfs:label "version";
    nt:hasRegex "[0-9].[0-9].[0-9]" .
  
  sub:website a nt:ExternalUriPlaceholder;
    rdfs:label "a link to a website with further information" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0003-2195-3997 .
}

