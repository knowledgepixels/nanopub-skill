sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  dct:contributor rdfs:label "has contributor" .
  
  dct:creator rdfs:label "has creator" .
  
  dct:date rdfs:label "has date" .
  
  dct:description rdfs:label "has description" .
  
  dct:publisher rdfs:label "has publisher" .
  
  dct:subject rdfs:label "has subject" .
  
  dct:title rdfs:label "has title" .
  
  dct:type rdfs:label "has datatype" .
  
  ns1:RAh4d0kYgEqvQG9mFX7Fdf77l6_7UyxmtETNUMRuQvfVU rdfs:label "image" .
  
  <http://www.w3.org/ns/dcat#accessURL> rdfs:label "has access URI" .
  
  <http://www.w3.org/ns/dcat#contactPoint> rdfs:label "has contact point" .
  
  <https://schema.org/variableMeasured> rdfs:label "has variable" .
  
  <https://w3id.org/np/RAX6NErJpmZtB9hbKcKNcOCYEfyCVr2UZVsstelI47iOA> rdfs:label "file" .
  
  sub:access a nt:UriPlaceholder;
    rdfs:label "access URI" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "test template only";
    rdfs:label "Describing dataset metadata based on DCAT";
    nt:hasNanopubLabelPattern "Metadata: Dataset";
    nt:hasStatement sub:st01, sub:st02, sub:st03, sub:st04, sub:st05, sub:st06, sub:st07,
      sub:st08, sub:st09, sub:st10, sub:st11;
    nt:hasTag "metadata";
    nt:hasTargetNanopubType <http://purl.org/spar/fabio/ScholarlyWork> .
  
  sub:contact-point a nt:UriPlaceholder;
    rdfs:label "ORCID of contact point" .
  
  sub:contributor a nt:UriPlaceholder;
    rdfs:label "ORCID of contributor" .
  
  sub:creator a nt:UriPlaceholder;
    rdfs:label "ORCID of creator" .
  
  sub:dataset a nt:IntroducedResource, nt:LocalResource, nt:UriPlaceholder;
    rdfs:label "dataset" .
  
  sub:date a nt:LiteralPlaceholder;
    rdfs:label "publication date (e.g. 2023-12-31)" .
  
  sub:description a nt:LiteralPlaceholder;
    rdfs:label "description" .
  
  sub:publisher a nt:UriPlaceholder;
    rdfs:label "ROR of publisher" .
  
  sub:st01 rdf:object sub:type;
    rdf:predicate dct:type;
    rdf:subject sub:dataset .
  
  sub:st02 rdf:object sub:title;
    rdf:predicate dct:title;
    rdf:subject sub:dataset .
  
  sub:st03 rdf:object sub:publisher;
    rdf:predicate dct:publisher;
    rdf:subject sub:dataset .
  
  sub:st04 rdf:object sub:date;
    rdf:predicate dct:date;
    rdf:subject sub:dataset .
  
  sub:st05 a nt:RepeatableStatement;
    rdf:object sub:creator;
    rdf:predicate dct:creator;
    rdf:subject sub:dataset .
  
  sub:st06 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:contributor;
    rdf:predicate dct:contributor;
    rdf:subject sub:dataset .
  
  sub:st07 rdf:object sub:contact-point;
    rdf:predicate <http://www.w3.org/ns/dcat#contactPoint>;
    rdf:subject sub:dataset .
  
  sub:st08 a nt:OptionalStatement;
    rdf:object sub:description;
    rdf:predicate dct:description;
    rdf:subject sub:dataset .
  
  sub:st09 a nt:RepeatableStatement;
    rdf:object sub:subject;
    rdf:predicate dct:subject;
    rdf:subject sub:dataset .
  
  sub:st10 a nt:RepeatableStatement;
    rdf:object sub:variable;
    rdf:predicate <https://schema.org/variableMeasured>;
    rdf:subject sub:dataset .
  
  sub:st11 rdf:object sub:access;
    rdf:predicate <http://www.w3.org/ns/dcat#accessURL>;
    rdf:subject sub:dataset .
  
  sub:subject a nt:RestrictedChoicePlaceholder;
    rdfs:label "subject";
    nt:possibleValuesFrom ns1:RACXDZHEowTYDAzZvdmD0qIGpXZwY5ghMRBBlt6N8Iu5s .
  
  sub:title a nt:LiteralPlaceholder;
    rdfs:label "title" .
  
  sub:type a nt:RestrictedChoicePlaceholder;
    rdfs:label "data type";
    nt:possibleValue ns1:RAh4d0kYgEqvQG9mFX7Fdf77l6_7UyxmtETNUMRuQvfVU, <https://w3id.org/np/RAX6NErJpmZtB9hbKcKNcOCYEfyCVr2UZVsstelI47iOA>,
      <https://w3id.org/np/RAwvNqa0ia4lY5Jetmcyh1sgfpRowZntd8WgMb8xEfmaY> .
  
  sub:variable a nt:RestrictedChoicePlaceholder;
    rdfs:label "variable";
    nt:possibleValuesFrom ns1:RApnw0CS0so_FXmFWg-DXi5Z7-jzZT3t57Mt97TSqINEI .
  
  <https://w3id.org/np/RAwvNqa0ia4lY5Jetmcyh1sgfpRowZntd8WgMb8xEfmaY> rdfs:label "record" .
}

