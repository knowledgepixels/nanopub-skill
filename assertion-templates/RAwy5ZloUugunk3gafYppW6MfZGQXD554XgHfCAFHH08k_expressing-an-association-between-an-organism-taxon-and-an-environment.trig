  sub:sig npx:hasAlgorithm "RSA";
    npx:hasPublicKey "MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQCjDGQCS1S+SRnERDuYDXOugdYUP0efEquHJEEHAbU/uLzBVlga89zqrNPCS7fBE6lArBUWEmT8eLKdMapyqvAzI1J3jUWTMhDJF+XFBkUiuiFfNSc4vJJcmi0yujtnuzXsRIG202jyaP4f5ULoskFwaZOSBZJfiE0dsB3D7DTIAQIDAQAB";
    npx:hasSignature "leTarJ33NCdhprZm85379+7sAlSnUD6sQlfNPgseu1v6QYokRb3hiUb6vHC0JXTQiKhGwB1i8V6v7xmfWeqX9VqPLnX8+SnUf1mpeVDTecNlzb5lhEzQkstddFyr4AsKSI0aX7D0lozxDcxiIhN+f7Co1qHBZxiHQJyEZLbubT8=";
    npx:hasSignatureTarget this: .
  
  this: dct:created "2023-09-08T09:14:23.053Z"^^xsd:dateTime;
