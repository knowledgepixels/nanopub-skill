sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  <http://w3id.org/aopdo#0042> rdfs:label "KeyEvent" .
  
  <http://w3id.org/aopdo#0063> rdfs:label "hasID" .
  
  sub:AOPName a nt:LiteralPlaceholder .
  
  sub:Action a nt:RestrictedChoicePlaceholder;
    nt:possibleValue sub:Decreased, sub:Increased .
  
  sub:ApplicabilityDomain a nt:LongLiteralPlaceholder .
  
  sub:AuthorStatus a nt:LiteralPlaceholder .
  
  sub:BiologicalOrganizationLevel a nt:RestrictedChoicePlaceholder;
    nt:possibleValue sub:Cell, sub:Community, sub:Individual, sub:Molecular, sub:Organ,
      sub:OrganSystem, sub:Population, sub:Tissue .
  
  sub:DOI a nt:LiteralPlaceholder .
  
  sub:Description a nt:LongLiteralPlaceholder .
  
  sub:ID a nt:LiteralPlaceholder .
  
  sub:LifeStage a nt:LiteralPlaceholder .
  
  sub:LifeStagesEvidence a nt:RestrictedChoicePlaceholder;
    nt:possibleValue sub:High, sub:Moderate .
  
  sub:MeasurementAndDetectionTechniques a nt:LongLiteralPlaceholder .
  
  sub:OECDStatus a nt:LiteralPlaceholder .
  
  sub:Object a nt:LiteralPlaceholder .
  
  sub:OrganTerm a nt:LiteralPlaceholder .
  
  sub:PointOfContact a nt:LiteralPlaceholder .
  
  sub:Process a nt:LiteralPlaceholder .
  
  sub:RoleInAOP a nt:LiteralPlaceholder .
  
  sub:ScientificTerm a nt:LiteralPlaceholder .
  
  sub:Sex a nt:RestrictedChoicePlaceholder;
    nt:possibleValue sub:Female, sub:Male .
  
  sub:SexApplicabilityEvidence a nt:RestrictedChoicePlaceholder;
    nt:possibleValue sub:High, sub:Moderate .
  
  sub:ShortName a nt:LiteralPlaceholder .
  
  sub:TaxonomicApplicabilityEvidence a nt:RestrictedChoicePlaceholder;
    nt:possibleValue sub:High, sub:Moderate .
  
  sub:Term a nt:LiteralPlaceholder .
  
  sub:Title a nt:LiteralPlaceholder .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Template to store data required to describe an AOP's KeyEvent following FAIR principles.";
    rdfs:label "KeyEvent Data Template";
    nt:hasStatement sub:st-1, sub:st0, sub:st1, sub:st2, sub:st3, sub:st4, sub:st4a, sub:st4b,
      sub:st4c, sub:st4d, sub:st5, sub:st6, sub:st7, sub:st8;
    nt:hasTag "AOPs Elements" .
  
  sub:st-1 a rdf:Statement;
    rdf:object sub:ID;
    rdf:predicate <http://w3id.org/aopdo#0063>;
    rdf:subject <http://w3id.org/aopdo#0042> .
  
  sub:st0 a rdf:Statement;
    rdf:object sub:Title;
    rdf:predicate sub:hasTitle;
    rdf:subject sub:KeyEvent .
  
  sub:st1 a rdf:Statement;
    rdf:object sub:ShortName;
    rdf:predicate sub:hasShortName;
    rdf:subject sub:KeyEvent .
  
  sub:st2 a nt:GroupedStatement, nt:OptionalStatement;
    rdf:object sub:BiologicalContext;
    rdf:predicate sub:hasBiologicalContext;
    rdf:subject sub:KeyEvent;
    nt:hasStatement sub:st2a, sub:st2b .
  
  sub:st2a rdf:object sub:BiologicalOrganizationLevel;
    rdf:predicate sub:hasBiologicalOrganizationLevel;
    rdf:subject sub:BiologicalContext .
  
  sub:st2b rdf:object sub:OrganTerm;
    rdf:predicate sub:hasOrganTerm;
    rdf:subject sub:BiologicalContext .
  
  sub:st3 a nt:GroupedStatement, nt:RepeatableStatement;
    rdf:object sub:Components;
    rdf:predicate sub:hasComponents;
    rdf:subject sub:KeyEvent;
    nt:hasStatement sub:st3a, sub:st3b, sub:st3c .
  
  sub:st3a rdf:object sub:Process;
    rdf:predicate sub:hasProcess;
    rdf:subject sub:Components .
  
  sub:st3b rdf:object sub:Object;
    rdf:predicate sub:hasObject;
    rdf:subject sub:Components .
  
  sub:st3c rdf:object sub:Action;
    rdf:predicate sub:hasAction;
    rdf:subject sub:Components .
  
  sub:st4 a nt:GroupedStatement;
    rdf:object sub:Overview;
    rdf:predicate sub:hasOverview;
    rdf:subject sub:KeyEvent;
    nt:hasStatement sub:st4a, sub:st4b, sub:st4c, sub:st4d .
  
  sub:st4a a nt:GroupedStatement, nt:RepeatableStatement;
    rdf:object sub:IncludedInAOP;
    rdf:predicate sub:hasIncludedInAOP;
    rdf:subject sub:Overview;
    nt:hasStatement sub:st4a1, sub:st4a2, sub:st4a3, sub:st4a4, sub:st4a5 .
  
  sub:st4a1 rdf:object sub:AOPName;
    rdf:predicate sub:hasAOPName;
    rdf:subject sub:IncludedInAOP .
  
  sub:st4a2 rdf:object sub:RoleInAOP;
    rdf:predicate sub:hasRoleInAOP;
    rdf:subject sub:IncludedInAOP .
  
  sub:st4a3 rdf:object sub:PointOfContact;
    rdf:predicate sub:hasPointOfContact;
    rdf:subject sub:IncludedInAOP .
  
  sub:st4a4 rdf:object sub:AuthorStatus;
    rdf:predicate sub:hasAuthorStatus;
    rdf:subject sub:IncludedInAOP .
  
  sub:st4a5 rdf:object sub:OECDStatus;
    rdf:predicate sub:hasOECDStatus;
    rdf:subject sub:IncludedInAOP .
  
  sub:st4b a nt:GroupedStatement, nt:RepeatableStatement;
    rdf:object sub:TaxonomicApplicability;
    rdf:predicate sub:hasTaxonomicApplicability;
    rdf:subject sub:Overview;
    nt:hasStatement sub:st4b1, sub:st4b2, sub:st4b3 .
  
  sub:st4b1 rdf:object sub:Term;
    rdf:predicate sub:hasTerm;
    rdf:subject sub:TaxonomicApplicability .
  
  sub:st4b2 rdf:object sub:ScientificTerm;
    rdf:predicate sub:hasScientificTerm;
    rdf:subject sub:TaxonomicApplicability .
  
  sub:st4b3 rdf:object sub:TaxonomicApplicabilityEvidence;
    rdf:predicate sub:hasEvidence;
    rdf:subject sub:TaxonomicApplicability .
  
  sub:st4c a nt:GroupedStatement, nt:RepeatableStatement;
    rdf:object sub:LifeStages;
    rdf:predicate sub:hasLifeStages;
    rdf:subject sub:Overview;
    nt:hasStatement sub:st4c1, sub:st4c2 .
  
  sub:st4c1 rdf:object sub:LifeStage;
    rdf:predicate sub:hasLifeStage;
    rdf:subject sub:LifeStages .
  
  sub:st4c2 rdf:object sub:LifeStagesEvidence;
    rdf:predicate sub:hasEvidence;
    rdf:subject sub:LifeStages .
  
  sub:st4d a nt:GroupedStatement, nt:RepeatableStatement;
    rdf:object sub:SexApplicability;
    rdf:predicate sub:hasSexApplicability;
    rdf:subject sub:Overview;
    nt:hasStatement sub:st4d1, sub:st4d2 .
  
  sub:st4d1 rdf:object sub:Sex;
    rdf:predicate sub:hasSex;
    rdf:subject sub:SexApplicability .
  
  sub:st4d2 rdf:object sub:SexApplicabilityEvidence;
    rdf:predicate sub:hasEvidence;
    rdf:subject sub:SexApplicability .
  
  sub:st5 rdf:object sub:Description;
    rdf:predicate sub:hasDescription;
    rdf:subject sub:KeyEvent .
  
  sub:st6 rdf:object sub:MeasurementAndDetectionTechniques;
    rdf:predicate sub:hasMeasurementAndDetectionTechniques;
    rdf:subject sub:KeyEvent .
  
  sub:st7 rdf:object sub:ApplicabilityDomain;
    rdf:predicate sub:hasApplicabilityDomain;
    rdf:subject sub:KeyEvent .
  
  sub:st8 a nt:GroupedStatement, nt:RepeatableStatement;
    rdf:object sub:References;
    rdf:predicate sub:hasReferences;
    rdf:subject sub:KeyEvent;
    nt:hasStatement sub:st8a, sub:st8b .
  
  sub:st8a rdf:object sub:Title;
    rdf:predicate sub:hasTitle;
    rdf:subject sub:References .
  
  sub:st8b rdf:object sub:DOI;
    rdf:predicate sub:hasDOI;
    rdf:subject sub:References .
}

