sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  <https://w3id.org/kpxl/gen/terms/plansToAttend> rdfs:label "plans to attend" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Such a nanopublication declares that the creator plans to attend an event.";
    rdfs:label "Declaring to plan to attend an event";
    nt:hasNanopubLabelPattern "Plan to attend: ${space}";
    nt:hasStatement sub:st1;
    nt:hasTag "Spaces";
    nt:hasTargetNanopubType <https://w3id.org/kpxl/gen/terms/plansToAttend> .
  
  sub:space a nt:ExternalUriPlaceholder;
    rdfs:label "URI of event" .
  
  sub:st1 rdf:object sub:space;
    rdf:predicate <https://w3id.org/kpxl/gen/terms/plansToAttend>;
    rdf:subject nt:CREATOR .
}

sub:provenance {
