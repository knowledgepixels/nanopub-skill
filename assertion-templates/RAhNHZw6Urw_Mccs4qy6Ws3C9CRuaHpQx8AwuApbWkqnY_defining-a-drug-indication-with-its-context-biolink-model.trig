    npx:hasSignature "iAatWmfjWSEn9Y+fQrjbn+LCcUdLV0Q3Wht3KH/7F35NuZyTI3dKqWrsg3qZrRLxOuL1Jdbkua8DgwZdSM3D5wY4Mb4ZGO14KD06Kok9FfRnOdjup0LXrg2a7enuXuLuexNnmKFVoC4AGrX8hrH8dE06II9wauAWL8FSY9OWMQI=";
