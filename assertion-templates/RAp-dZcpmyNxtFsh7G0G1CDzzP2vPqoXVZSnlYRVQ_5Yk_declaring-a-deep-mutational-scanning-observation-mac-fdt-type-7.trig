@prefix this: <https://w3id.org/np/RAp-dZcpmyNxtFsh7G0G1CDzzP2vPqoXVZSnlYRVQ_5Yk> .
@prefix sub: <https://w3id.org/np/RAp-dZcpmyNxtFsh7G0G1CDzzP2vPqoXVZSnlYRVQ_5Yk/> .
@prefix np: <http://www.nanopub.org/nschema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix nt: <https://w3id.org/np/o/ntemplate/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix orcid: <https://orcid.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix mac: <https://w3id.org/spaces/mac/r/ontology/> .
@prefix npx: <http://purl.org/nanopub/x/> .

sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  dct:contributor rdfs:label "has contributor" .
  
  dct:creator rdfs:label "has creator" .
  
  dct:isPartOf rdfs:label "is part of" .
  
  dct:license rdfs:label "data usage license" .
  
  dct:publisher rdfs:label "has publisher" .
  
  dct:references rdfs:label "references" .
  
  dct:source rdfs:label "has source" .
  
  dct:subject rdfs:label "has domain" .
  
  <http://purl.org/spar/cito/citesAsAuthority> rdfs:label "cites as authority" .
  
  rdf:type rdfs:label "is a" .
  
  rdfs:comment rdfs:label "has description" .
  
  rdfs:label rdfs:label "has the label" .
  
  <https://creativecommons.org/licenses/by/4.0/> rdfs:label "Attribution 4.0 International (CC BY 4.0)" .
  
  <https://doi.org/10.3389/fbinf.2025.1634111> rdfs:label "FAIR² data article (Frontiers in Bioinformatics)" .
  
  <https://doi.org/10.71728/hw56-vj34> rdfs:label "FAIR² Data Package DOI" .
  
  <https://w3id.org/fair/fip/terms/implements> rdfs:label "implements" .
  
  <https://w3id.org/fdof/ontology#FAIRDigitalObject> rdfs:label "FAIR Digital Object (FDO)" .
  
  <https://w3id.org/fdof/ontology#hasEncodingFormat> rdfs:label "has format" .
  
  <https://w3id.org/fdof/ontology#hasMetadata> rdfs:label "has its metadata in" .
  
  <https://w3id.org/fdof/ontology#materializes> rdfs:label "is a concrete materialization of" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Experimental binding affinity and expression level measurements for a SARS-CoV-2 Spike RBD variant determined by deep mutational scanning (Bloom Lab). One FDO per variant. Carries six measured values: bind (log KD, unitless), delta_bind (vs. wild-type), expr (log MFI, unitless), delta_expr, and confidence scores for bind and expr. Links via mac:isObservationOf to the variant FDO it observes and via mac:hasExperimentalMethod to the Bloom Lab DMS Method FDO (Type 10). The nanopublication self-materializes (assertion graph is the FDO).";
    rdfs:label "Declaring a Deep Mutational Scanning Observation (MAC FDT Type 7)";
    nt:hasNanopubLabelPattern "DMS observation (bind=${bind}, expr=${expr})";
    nt:hasStatement sub:st0, sub:st1, sub:st2, sub:st3, sub:st4, sub:st5, sub:st5b, sub:st5c,
      sub:st5d, sub:st6, sub:st7, sub:st8, sub:st91, sub:st92, sub:st95, sub:st_bi, sub:st_cb,
      sub:st_ce, sub:st_db, sub:st_de, sub:st_em, sub:st_ex, sub:st_obs, sub:st_oc, sub:st_pp,
      sub:st_src;
    nt:hasTag "MAC" .
  
  sub:authority a nt:ExternalUriPlaceholder;
    rdfs:label "observation-specific authority (DOI or URL)" .
  
  sub:bind a nt:LiteralPlaceholder;
    rdfs:label "bind (binding affinity, log KD, unitless)" .
  
  sub:confidenceBind a nt:LiteralPlaceholder;
    rdfs:label "confidence_bind (unitless)" .
  
  sub:confidenceExpr a nt:LiteralPlaceholder;
    rdfs:label "confidence_expr (unitless)" .
  
  sub:contact a nt:LiteralPlaceholder;
    rdfs:label "contact email" .
  
  sub:contributor a nt:AgentPlaceholder;
    rdfs:label "ORCID of contributor" .
  
  sub:creator a nt:AgentPlaceholder;
    rdfs:label "ORCID of creator";
    nt:hasDefaultValue nt:CREATOR .
  
  sub:deltaBind a nt:LiteralPlaceholder;
    rdfs:label "delta_bind (change vs. wild-type, unitless)" .
  
  sub:deltaExpr a nt:LiteralPlaceholder;
    rdfs:label "delta_expr (change vs. wild-type, unitless)" .
  
  sub:description a nt:LongLiteralPlaceholder;
    rdfs:label "free-text description of this DMS observation" .
  
  sub:domain a nt:RestrictedChoicePlaceholder;
    rdfs:label "domain";
    nt:possibleValuesFrom <https://w3id.org/np/RACXDZHEowTYDAzZvdmD0qIGpXZwY5ghMRBBlt6N8Iu5s> .
  
  sub:experimentalMethod a nt:ExternalUriPlaceholder;
    rdfs:label "Experimental Method FDO referent URI (Type 10)" .
  
  sub:expr a nt:LiteralPlaceholder;
    rdfs:label "expr (expression level, log MFI, unitless)" .
  
  sub:fdo a nt:IntroducedResource, nt:LocalResource, nt:UriPlaceholder;
    rdfs:label "full URI or short suffix for this DMS observation FDO" .
  
  sub:fip a nt:GuidedChoicePlaceholder;
    rdfs:label "FAIR Implementation Profile";
    nt:possibleValuesFromApi "http://purl.org/nanopub/api/find_signed_things?type=https%3A%2F%2Fw3id.org%2Ffair%2Ffip%2Fterms%2FFAIR-Implementation-Profile&searchterm=" .
  
  sub:label a nt:LiteralPlaceholder;
    rdfs:label "label for this observation (e.g. \"Alpha DMS - Bloom Lab\")" .
  
  sub:project a nt:GuidedChoicePlaceholder;
    rdfs:label "project";
    nt:possibleValuesFromApi "https://w3id.org/np/l/nanopub-query-1.1/api/RAFTZ8GqPOOJQOBcEo5IB8lg5vZCFiIyr_RVLKZDQBHMk/get-projects?searchterm=" .
  
  sub:publisher a nt:ExternalUriPlaceholder;
    rdfs:label "ROR of the publishing entity" .
  
  sub:source a nt:ExternalUriPlaceholder;
    rdfs:label "FAIR² Package DOI, FAIR² resource URL, or OSF URL" .
  
  sub:st0 rdf:object <https://w3id.org/fdof/ontology#FAIRDigitalObject>;
    rdf:predicate rdf:type;
    rdf:subject sub:fdo .
  
  sub:st1 a nt:OptionalStatement;
    rdf:object sub:label;
    rdf:predicate rdfs:label;
    rdf:subject sub:fdo .
  
  sub:st2 a nt:OptionalStatement;
    rdf:object sub:description;
    rdf:predicate rdfs:comment;
    rdf:subject sub:fdo .
  
  sub:st3 rdf:object mac:ExperimentalDMSObservation;
    rdf:predicate rdf:type;
    rdf:subject sub:fdo .
  
  sub:st4 rdf:object nt:NANOPUB;
    rdf:predicate <https://w3id.org/fdof/ontology#hasMetadata>;
    rdf:subject sub:fdo .
  
  sub:st5 rdf:object sub:fdo;
    rdf:predicate <https://w3id.org/fdof/ontology#materializes>;
    rdf:subject nt:NANOPUB .
  
  sub:st5b rdf:object <https://www.iana.org/assignments/media-types/application/trig>;
    rdf:predicate <https://w3id.org/fdof/ontology#hasEncodingFormat>;
    rdf:subject nt:NANOPUB .
  
  sub:st5c rdf:object <https://creativecommons.org/licenses/by/4.0/>;
    rdf:predicate dct:license;
    rdf:subject nt:NANOPUB .
  
  sub:st5d rdf:object nt:NANOPUB;
    rdf:predicate <https://www.w3.org/ns/dcat#accessURL>;
    rdf:subject nt:NANOPUB .
  
  sub:st6 a nt:RepeatableStatement;
    rdf:object sub:creator;
    rdf:predicate dct:creator;
    rdf:subject sub:fdo .
  
  sub:st7 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:contributor;
    rdf:predicate dct:contributor;
    rdf:subject sub:fdo .
  
  sub:st8 rdf:object sub:contact;
    rdf:predicate <https://www.w3.org/ns/dcat#contactPoint>;
    rdf:subject sub:fdo .
  
  sub:st91 a nt:OptionalStatement;
    rdf:object sub:domain;
    rdf:predicate dct:subject;
    rdf:subject sub:fdo .
  
  sub:st92 rdf:object sub:publisher;
    rdf:predicate dct:publisher;
    rdf:subject sub:fdo .
  
  sub:st95 a nt:OptionalStatement;
    rdf:object sub:fip;
    rdf:predicate <https://w3id.org/fair/fip/terms/implements>;
    rdf:subject sub:fdo .
  
  sub:st_bi rdf:object sub:bind;
    rdf:predicate mac:hasBind;
    rdf:subject sub:fdo .
  
  sub:st_cb rdf:object sub:confidenceBind;
    rdf:predicate mac:hasConfidenceBind;
    rdf:subject sub:fdo .
  
  sub:st_ce rdf:object sub:confidenceExpr;
    rdf:predicate mac:hasConfidenceExpr;
    rdf:subject sub:fdo .
  
  sub:st_db rdf:object sub:deltaBind;
    rdf:predicate mac:hasDeltaBind;
    rdf:subject sub:fdo .
  
  sub:st_de rdf:object sub:deltaExpr;
    rdf:predicate mac:hasDeltaExpr;
    rdf:subject sub:fdo .
  
  sub:st_em rdf:object sub:experimentalMethod;
    rdf:predicate mac:hasExperimentalMethod;
    rdf:subject sub:fdo .
  
  sub:st_ex rdf:object sub:expr;
    rdf:predicate mac:hasExpr;
    rdf:subject sub:fdo .
  
  sub:st_obs rdf:object sub:variant;
    rdf:predicate mac:isObservationOf;
    rdf:subject sub:fdo .
  
  sub:st_oc a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:authority;
    rdf:predicate <http://purl.org/spar/cito/citesAsAuthority>;
    rdf:subject sub:fdo .
  
  sub:st_pp rdf:object sub:project;
    rdf:predicate dct:isPartOf;
    rdf:subject sub:fdo .
  
  sub:st_src a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:source;
    rdf:predicate dct:source;
    rdf:subject sub:fdo .
  
  sub:variant a nt:ExternalUriPlaceholder;
    rdfs:label "Spike RBD Variant FDO referent URI" .
  
  mac:ExperimentalDMSObservation rdfs:label "Experimental DMS Observation" .
  
  mac:hasBind rdfs:label "has bind (binding affinity, log KD, unitless)" .
  
  mac:hasConfidenceBind rdfs:label "has confidence_bind (unitless)" .
  
  mac:hasConfidenceExpr rdfs:label "has confidence_expr (unitless)" .
  
  mac:hasDeltaBind rdfs:label "has delta_bind (vs. wild-type, unitless)" .
  
  mac:hasDeltaExpr rdfs:label "has delta_expr (vs. wild-type, unitless)" .
  
  mac:hasExperimentalMethod rdfs:label "has experimental method" .
  
  mac:hasExpr rdfs:label "has expr (expression level, log MFI, unitless)" .
  
  mac:isObservationOf rdfs:label "is observation of" .
  
  <https://www.iana.org/assignments/media-types/application/trig> rdfs:label "TriG (RDF named-graph serialization)" .
  
  <https://www.w3.org/ns/dcat#accessURL> rdfs:label "has access URL" .
  
  <https://www.w3.org/ns/dcat#contactPoint> rdfs:label "has contact point" .
}

