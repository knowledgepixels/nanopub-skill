    rdf:subject sub:policy .
  
  sub:title a nt:LiteralPlaceholder;
    rdfs:label "the title of the policy" .
  
  rdf:type rdfs:label "is a" .
  
  <http://www.wikidata.org/entity/Q1156854> rdfs:label "Policy" .
}

