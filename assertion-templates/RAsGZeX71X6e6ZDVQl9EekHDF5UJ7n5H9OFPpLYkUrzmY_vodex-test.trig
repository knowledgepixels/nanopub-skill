sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:assertion a nt:AssertionTemplate, nt:UnlistedTemplate;
    rdfs:label "vodex test";
    nt:hasStatement sub:st1 .
  
  sub:species a nt:GuidedChoicePlaceholder;
    rdfs:label "NCBI Taxon species identifier";
    nt:possibleValuesFromApi "https://vodex.petapico.org/ncbitaxon/query?q=label:" .
  
  sub:st1 rdf:object sub:species;
    rdf:predicate rdf:type;
    rdf:subject sub:organism .
  
  rdf:type rdfs:label "is a" .
}

sub:provenance {
