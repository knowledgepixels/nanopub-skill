sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  rdf:type rdfs:label "is a" .
  
  rdfs:comment rdfs:label "has the description" .
  
  rdfs:label rdfs:label "has title" .
  
  rdfs:seeAlso rdfs:label "further described on", "is further described by" .
  
  <https://schema.org/spatialCoverage> rdfs:label "covered area" .
  
  <https://schema.org/temporalCoverage> rdfs:label "time period covered" .
  
  <https://w3id.org/fair/fip/terms/has-description-source> rdfs:label "has description source" .
  
  sub:area a nt:ExternalUriPlaceholder;
    rdfs:label "geographical area (NUTS)" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Template for defining a Case Study";
    rdfs:label "Defining a Case study";
    nt:hasRequiredPubinfoElement ns1:RA_R5w4lZ-6xuZyylG8qSlMhmWBaTE41-zlhiBVUQblCc;
    nt:hasStatement sub:st01, sub:st02, sub:st03, sub:st04, sub:st05, sub:st06, sub:st07,
      sub:st07a, sub:st11, sub:st12, sub:st13, sub:st14, sub:st15, sub:st16, sub:st17;
    nt:hasTag "FAIR" .
  
  sub:case a nt:IntroducedResource, nt:LocalResource, nt:UriPlaceholder;
    rdfs:label "case study" .
  
  sub:caseInfo a nt:ExternalUriPlaceholder;
    rdfs:label "URI of case study website" .
  
  sub:challenge a nt:LiteralPlaceholder;
    rdfs:label "challenge" .
  
  sub:contact a nt:AgentPlaceholder;
    rdfs:label "contact person (ORCID)" .
  
  sub:description a nt:LiteralPlaceholder;
    rdfs:label "description" .
  
  sub:domain a nt:RestrictedChoicePlaceholder;
    rdfs:label "research domain";
    nt:possibleValuesFromApi "http://purl.org/np/RACXDZHEowTYDAzZvdmD0qIGpXZwY5ghMRBBlt6N8Iu5s" .
  
  sub:duration a nt:LiteralPlaceholder;
    rdfs:label "duration period" .
  
  sub:goal a nt:LiteralPlaceholder;
    rdfs:label "goal" .
  
  sub:name a nt:LiteralPlaceholder;
    rdfs:label "title" .
  
  sub:organisation a nt:ExternalUriPlaceholder;
    rdfs:label "organisation" .
  
  sub:project a nt:ExternalUriPlaceholder;
    rdfs:label "project" .
  
  sub:projectname a nt:LiteralPlaceholder;
    rdfs:label "the name of the project" .
  
  sub:source a nt:ExternalUriPlaceholder;
    rdfs:label "source of description" .
  
  sub:st01 rdf:object <https://w3id/fff/req/Case-Study>;
    rdf:predicate rdf:type;
    rdf:subject sub:case .
  
  sub:st02 rdf:object sub:name;
    rdf:predicate rdfs:label;
    rdf:subject sub:case .
  
  sub:st03 rdf:object sub:description;
    rdf:predicate rdfs:comment;
    rdf:subject sub:case .
  
  sub:st04 rdf:object sub:source;
    rdf:predicate <https://w3id.org/fair/fip/terms/has-description-source>;
    rdf:subject sub:case .
  
  sub:st05 rdf:object sub:contact;
    rdf:predicate <https://www.w3.org/ns/dcat#contactPoint>;
    rdf:subject sub:case .
  
  sub:st06 rdf:object sub:organisation;
    rdf:predicate <https://w3id/fff/req/coordinated-by>;
    rdf:subject sub:case .
  
  sub:st07 a nt:OptionalStatement, nt:RepeatableStatement;
    rdf:object sub:organisation;
    rdf:predicate <https://w3id/fff/req/has-member>;
    rdf:subject sub:case .
  
  sub:st07a a nt:GroupedStatement, nt:RepeatableStatement;
    nt:hasStatement sub:st08, sub:st10 .
  
  sub:st08 rdf:object sub:projectname;
    rdf:predicate <https://w3id/fff/req/part-of-project>;
    rdf:subject sub:case .
  
  sub:st10 rdf:object sub:website;
    rdf:predicate rdfs:seeAlso;
    rdf:subject sub:project .
  
  sub:st11 a nt:RepeatableStatement;
    rdf:object sub:domain;
    rdf:predicate <https://w3id/fff/req/covers-domain>;
    rdf:subject sub:case .
  
  sub:st12 a nt:RepeatableStatement;
    rdf:object sub:area;
    rdf:predicate <https://schema.org/spatialCoverage>;
    rdf:subject sub:case .
  
  sub:st13 rdf:object sub:duration;
    rdf:predicate <https://schema.org/temporalCoverage>;
    rdf:subject sub:case .
  
  sub:st14 a nt:RepeatableStatement;
    rdf:object sub:challenge;
    rdf:predicate <https://w3id/fff/req/has-challenge>;
    rdf:subject sub:case .
  
  sub:st15 a nt:RepeatableStatement;
    rdf:object sub:goal;
    rdf:predicate <https://w3id/fff/req/has-goal>;
    rdf:subject sub:case .
  
  sub:st16 rdf:object sub:caseInfo;
    rdf:predicate rdfs:seeAlso;
    rdf:subject sub:case .
  
  sub:st17 a nt:RepeatableStatement;
    rdf:object sub:story;
    rdf:predicate <https://w3id/fff/req/has-user-story>;
    rdf:subject sub:case .
  
  sub:story a nt:GuidedChoicePlaceholder;
    rdfs:label "user story";
    nt:possibleValuesFromApi "http://purl.org/nanopub/api/find_signed_things?type=https://w3id.org/fff/req/User-Story" .
  
  sub:website a nt:ExternalUriPlaceholder;
    rdfs:label "website" .
  
  <https://w3id/fff/req/Case-Study> rdfs:label "case study" .
  
  <https://w3id/fff/req/coordinated-by> rdfs:label "is coordinated by" .
  
  <https://w3id/fff/req/covers-domain> rdfs:label "covers domain" .
  
  <https://w3id/fff/req/has-challenge> rdfs:label "has challenge" .
  
  <https://w3id/fff/req/has-goal> rdfs:label "has goal" .
  
  <https://w3id/fff/req/has-member> rdfs:label "has member" .
  
  <https://w3id/fff/req/has-user-story> rdfs:label "has user story" .
  
  <https://w3id/fff/req/part-of-project> rdfs:label "is part of project" .
  
  <https://www.w3.org/ns/dcat#contactPoint> rdfs:label "has contact point" .
}

