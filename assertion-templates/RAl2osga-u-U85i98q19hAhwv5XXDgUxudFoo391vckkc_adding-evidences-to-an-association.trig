    npx:hasSignature "j8b13MFRxVRq3shtONR1ezRxjTLzZW2G+ZNSguzkM/kmLH7fDYPQJZyuAWosOGi5QomhSoItGoOoJrSIGVozjhaIjaqln6vJLlIyDaZUiKHE1kOSPCMYi4oOpzR+MBODA1g1I669ZMBDiWkq3yKSvdx/CC46cC2RUZCic1PjEpQ=";
    npx:hasSignatureTarget this: .
  
  this: dcterms:created "2020-09-18T11:00:00+01:00"^^xsd:dateTime;
