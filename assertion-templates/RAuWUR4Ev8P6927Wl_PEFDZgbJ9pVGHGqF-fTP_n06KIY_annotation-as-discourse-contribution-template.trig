sub:assertion {
  <https://w3id.org/np/RATxyPikKUvLwqijI4T_fvaHE758DsxgXhOq0m6KiLlEI/templateKind> a
      gen:MaintainedResource, nt:AssertionTemplate;
    dct:description "Template for a Web Annotation whose body is a discourse statement taking a typed (CiTO) stance toward, and/or replying to, the annotated target. oa:hasBody references the statement by IRI, so the body is an external web resource. The target is an oa:SpecificResource, optionally narrowed to a passage with an oa:TextQuoteSelector.";
    rdfs:label "Annotation as Discourse Contribution Template";
    gen:isMaintainedBy <https://w3id.org/spaces/knowledgepixels/nanoarguments> .
}

