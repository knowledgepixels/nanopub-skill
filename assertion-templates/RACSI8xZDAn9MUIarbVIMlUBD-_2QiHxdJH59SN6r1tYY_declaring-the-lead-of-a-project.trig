sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  <https://w3id.org/kpxl/gen/terms/hasProjectLead> rdfs:label "has the project lead" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "Such a nanopublication declares that somebody is the project lead of a given project";
    rdfs:label "Declaring the lead of a project";
    nt:hasNanopubLabelPattern "${space} has lead ${lead}";
    nt:hasStatement sub:st1;
    nt:hasTag "Spaces" .
  
  sub:lead a nt:AgentPlaceholder;
    rdfs:label "choose the project lead" .
  
  sub:space a nt:GuidedChoicePlaceholder;
    rdfs:label "choose the project";
    nt:possibleValuesFromApi "https://w3id.org/np/l/nanopub-query-1.1/api/RAyMrQ89RECTi9gZK5q7gjL1wKTiP8StkLy0NIkkCiyew/find-things?type=https://w3id.org/kpxl/gen/terms/Project" .
  
  sub:st1 rdf:object sub:lead;
    rdf:predicate <https://w3id.org/kpxl/gen/terms/hasProjectLead>;
    rdf:subject sub:space .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

