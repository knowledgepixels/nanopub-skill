sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  <https://w3id.org/kpxl/gen/terms/hasMaintainer> rdfs:label "has maintainer" .
  
  sub:admin a nt:AgentPlaceholder;
    rdfs:label "an admin of the Space" .
  
  sub:assertion a nt:AssertionTemplate;
    rdfs:label "Declaring a maintainer of a Space";
    nt:hasNanopubLabelPattern "${space} has maintainer ${admin}";
    nt:hasStatement sub:st1;
    nt:hasTag "Spaces";
    nt:hasTargetNanopubType <https://w3id.org/kpxl/gen/terms/RoleInstantiation> .
  
  sub:space a nt:GuidedChoicePlaceholder;
    rdfs:label "choose a Space";
    nt:possibleValuesFromApi "https://w3id.org/np/l/nanopub-query-1.1/api/RAyMrQ89RECTi9gZK5q7gjL1wKTiP8StkLy0NIkkCiyew/find-things?type=https://w3id.org/kpxl/gen/terms/Space&searchterm=" .
  
  sub:st1 rdf:object sub:admin;
    rdf:predicate <https://w3id.org/kpxl/gen/terms/hasMaintainer>;
    rdf:subject sub:space .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

