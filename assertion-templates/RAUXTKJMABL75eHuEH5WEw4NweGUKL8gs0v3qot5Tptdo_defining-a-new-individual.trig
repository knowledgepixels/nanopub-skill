    npx:hasSignature "WjcRf2N1jgtng8Adgt99zKfR4UL4FnT3XXVgFVOwKqBMX71XxThU1DnW8YUpmS9+AP0ezWCJhydAREupo6TgnxxBIZgzUNsupZUQhpPCyXvMfzP8zXldSKWCr+dhfFJ/+16MBHP7FS0Pz/pgkMp8bLs00L3/gypSUc8UARcrL7w=";
