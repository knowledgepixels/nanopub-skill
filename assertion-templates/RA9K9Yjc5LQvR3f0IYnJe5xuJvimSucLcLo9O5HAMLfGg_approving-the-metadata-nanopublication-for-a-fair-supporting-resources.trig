  sub:curator a nt:UriPlaceholder;
    rdfs:label "URI of curator (organization)" .
  
  sub:nanopub a nt:TrustyUriPlaceholder;
    rdfs:label "nanopublication URI" .
  
  sub:st1 a rdf:Statement;
    rdf:object sub:nanopub;
    rdf:predicate npx:qualifies;
    rdf:subject sub:curator;
    nt:statementOrder "1" .
}

