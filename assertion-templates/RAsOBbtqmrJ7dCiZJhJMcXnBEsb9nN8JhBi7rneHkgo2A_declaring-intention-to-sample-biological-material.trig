sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:assertion a nt:AssertionTemplate, nt:UnlistedTemplate;
    rdfs:label "Declaring intention to sample biological material";
    nt:hasStatement sub:st01, sub:st02 .
  
  sub:intention a nt:IntroducedResource .
  
  sub:st01 rdf:object <http://example.org/samplingIntention>;
    rdf:predicate rdf:type;
    rdf:subject sub:intention .
  
  sub:st02 rdf:object sub:targetMaterial;
    rdf:predicate <http://example.org/hasTargetMaterial>;
    rdf:subject sub:intention .
  
  sub:targetMaterial a nt:GuidedChoicePlaceholder;
    nt:possibleValuesFromApi "https://www.ebi.ac.uk/ols/api/select?ontology=envo&q=" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0001-6534-6609 .
}

sub:pubinfo {
  orcid:0000-0001-6534-6609 foaf:name "Mitja M. Zdouc" .
  
  this: dct:created "2026-07-08T13:26:02.403Z"^^xsd:dateTime;
