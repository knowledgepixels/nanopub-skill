    npx:hasSignature "KvP7VF+bOy40k2uWOYm+go8DKMnTufGXzA/EWD/Sir1ECeePVzvC6hYZmDkZLEezchIEcnUpEMX9lGhOgX3n+acUv1hG/wThcbHqUYFo5gt7KGhzJNAfOMoYBs1OCDKq5q0GNibVkJnjI4dmheq9wPQgJLfhliwuwIN3JGUTEsk=";
    npx:hasSignatureTarget this: .
  
  this: dcterms:created "2021-04-08T18:00:00.000+01:00"^^xsd:dateTime;
    dcterms:creator orcid:0000-0001-7769-4272;
