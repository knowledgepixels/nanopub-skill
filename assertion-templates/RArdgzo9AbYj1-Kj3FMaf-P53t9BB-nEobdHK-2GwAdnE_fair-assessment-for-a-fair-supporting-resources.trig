sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:assertion a nt:AssertionTemplate;
    rdfs:label "FAIR assessment for a FAIR Supporting Resources";
    nt:hasDefaultProvenance <https://w3id.org/np/RAtITn5jr8HALUQtIwxt7b-UN1c969mWlcB0S2oubTmY4>;
    nt:hasNanopubLabelPattern "Qualification of: ${nanopub}";
    nt:hasStatement sub:st1, sub:st2;
    nt:hasTag "3PFF" .
  
  sub:assessment a nt:ExternalUriPlaceholder;
    rdfs:label "assessment report" .
  
  sub:level a nt:RestrictedChoicePlaceholder;
    rdfs:label "FAIRness assessment level";
    nt:possibleValue <https://w3id.org/fair/fip/terms/1-of-5-Levels>, <https://w3id.org/fair/fip/terms/2-of-5-Levels>,
      <https://w3id.org/fair/fip/terms/3-of-5-Levels>, <https://w3id.org/fair/fip/terms/4-of-5-Levels>,
      <https://w3id.org/fair/fip/terms/5-of-5-Levels> .
  
  sub:resource a nt:ExternalUriPlaceholder, nt:LocalResource .
  
  sub:st1 rdf:object sub:level;
    rdf:predicate <https://w3id.org/fair/fip/terms/has-FAIR-assessment>;
    rdf:subject sub:resource;
    nt:statementOrder "1" .
  
  sub:st2 a nt:OptionalStatement;
    rdf:object sub:assessment;
    rdf:predicate rdfs:seeAlso;
    rdf:subject sub:resource;
    nt:statementOrder "2" .
}

