sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  <https://w3id.org/kpxl/gen/terms/hasRole> rdfs:label "has the role" .
  
  sub:assertion a nt:AssertionTemplate;
    rdfs:label "Assigning a role to a Space";
    nt:hasNanopubLabelPattern "${space} has role: ${role}";
    nt:hasStatement sub:st01;
    nt:hasTag "Spaces";
    nt:hasTargetNanopubType <https://w3id.org/kpxl/gen/terms/SpaceMemberRole> .
  
  sub:role a nt:GuidedChoicePlaceholder;
    rdfs:label "select the role";
    nt:possibleValuesFromApi "https://w3id.org/np/l/nanopub-query-1.1/api/RAyMrQ89RECTi9gZK5q7gjL1wKTiP8StkLy0NIkkCiyew/find-things?type=https://w3id.org/kpxl/gen/terms/SpaceMemberRole" .
  
  sub:space a nt:GuidedChoicePlaceholder;
    rdfs:label "select the space";
    nt:possibleValuesFromApi "https://w3id.org/np/l/nanopub-query-1.1/api/RAyMrQ89RECTi9gZK5q7gjL1wKTiP8StkLy0NIkkCiyew/find-things?type=https://w3id.org/kpxl/gen/terms/Space" .
  
  sub:st01 rdf:object sub:role;
    rdf:predicate <https://w3id.org/kpxl/gen/terms/hasRole>;
    rdf:subject sub:space .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

