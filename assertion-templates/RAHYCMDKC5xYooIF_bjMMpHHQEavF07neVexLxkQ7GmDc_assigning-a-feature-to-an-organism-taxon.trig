sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:assertion a nt:AssertionTemplate;
    rdfs:label "Assigning a feature to an organism taxon";
    nt:hasNanopubLabelPattern "${taxon} has the feature ${feature}";
    nt:hasStatement sub:st .
  
  sub:feature a nt:GuidedChoicePlaceholder;
    rdfs:label "choose biological feature";
    nt:possibleValuesFromApi "https://www.wikidata.org/w/api.php?action=wbsearchentities&language=en&format=json&limit=5&search=" .
  
  sub:st rdf:object sub:feature;
    rdf:predicate <https://w3id.org/spaces/carabid-beetles/r/ontology/hasFeature>;
    rdf:subject sub:taxon .
  
  sub:taxon a nt:GuidedChoicePlaceholder;
    rdfs:label "choose taxon";
    nt:possibleValuesFromApi "https://vodex.petapico.org/nidx/query?rows=100&q=label:" .
  
  <https://w3id.org/spaces/carabid-beetles/r/ontology/hasFeature> rdfs:label "has the feature" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

