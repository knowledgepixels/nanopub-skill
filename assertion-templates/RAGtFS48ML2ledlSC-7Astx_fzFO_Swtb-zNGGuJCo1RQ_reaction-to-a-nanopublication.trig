sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:assertion a nt:AssertionTemplate;
    rdfs:label "Reaction to a NanoPublication";
    nt:hasNanopubLabelPattern "React to: ${thing}";
    nt:hasStatement sub:s1;
    nt:hasTag "Reacts" .
  
  sub:reaction a nt:LiteralPlaceholder;
    nt:hasRegex ".{1}" .
  
  sub:s1 a rdf:Statement;
    rdf:object sub:reaction;
    rdf:predicate <http://rdfs.org/sioc/ns#has_reply>;
    rdf:subject sub:thing .
  
  sub:thing a nt:UriPlaceholder .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0009-0009-6638-993X .
}

