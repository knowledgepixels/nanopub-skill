sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:assertion a nt:AssertionTemplate, nt:UnlistedTemplate;
    rdfs:label "OpenAIRE test";
    nt:hasStatement sub:st1, sub:st2, sub:st3 .
  
  sub:org a nt:GuidedChoicePlaceholder;
    rdfs:label "organization";
    nt:possibleValuesFromApi "https://api.openaire.eu/graph/v1/organizations?search=" .
  
  sub:person a nt:GuidedChoicePlaceholder;
    rdfs:label "persons";
    nt:possibleValuesFromApi "https://api.openaire.eu/graph/v1/persons?search=" .
  
  sub:prod a nt:GuidedChoicePlaceholder;
    rdfs:label "research product";
    nt:possibleValuesFromApi "https://api.openaire.eu/graph/v2/researchProducts?search=" .
  
  sub:proj a nt:GuidedChoicePlaceholder;
    rdfs:label "projects";
    nt:possibleValuesFromApi "https://api.openaire.eu/graph/v1/projects?search=" .
  
  sub:src a nt:GuidedChoicePlaceholder;
    rdfs:label "data sources";
    nt:possibleValuesFromApi "https://api.openaire.eu/graph/v1/dataSources?search=" .
  
  sub:st1 rdf:object sub:prod;
    rdf:predicate <http://example.org/pred>;
    rdf:subject sub:org .
  
  sub:st2 rdf:object sub:proj;
    rdf:predicate <http://example.org/pred>;
    rdf:subject sub:src .
  
  sub:st3 rdf:object sub:person;
    rdf:predicate <http://example.org/pred>;
    rdf:subject sub:org .
}

