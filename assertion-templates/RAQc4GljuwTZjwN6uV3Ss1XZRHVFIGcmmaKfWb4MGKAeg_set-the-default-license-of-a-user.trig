sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  <https://creativecommons.org/licenses/by-sa/4.0/> rdfs:label "Attribution-NonCommercial-ShareAlike 4.0 International",
      "Attribution-ShareAlike 4.0 International (CC BY-SA 4.0)" .
  
  <https://creativecommons.org/licenses/by/4.0/> rdfs:label "Attribution 4.0 International (CC BY 4.0)" .
  
  <https://creativecommons.org/publicdomain/zero/1.0/> rdfs:label "CC0 1.0 Universal (CC0 1.0) Public Domain Dedication" .
  
  <https://w3id.org/kpxl/gen/terms/hasDefaultLicense> rdfs:label "has the default license" .
  
  sub:assertion a nt:AssertionTemplate;
    dct:description "This template is used to set the default license with which the nanopublications of a User are published. (plus non-commercial)";
    rdfs:label "Set the default license of a User";
    nt:hasStatement sub:st .
  
  sub:license a nt:RestrictedChoicePlaceholder;
    rdfs:label "select the license here";
    nt:hasDefaultValue <https://creativecommons.org/licenses/by/4.0/>;
    nt:possibleValue <https://creativecommons.org/licenses/by-nc-sa/4.0/>, <https://creativecommons.org/licenses/by-sa/4.0/>,
      <https://creativecommons.org/licenses/by/4.0/>, <https://creativecommons.org/publicdomain/zero/1.0/> .
  
  sub:st rdf:object sub:license;
    rdf:predicate <https://w3id.org/kpxl/gen/terms/hasDefaultLicense>;
    rdf:subject sub:user .
  
  sub:user a nt:AgentPlaceholder;
    nt:hasDefaultValue nt:CREATOR .
}

