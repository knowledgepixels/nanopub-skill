  <https://mapping-commons.github.io/sssom/reviewer_id/> rdfs:label "has reviewer_id" .
  
  <https://mapping-commons.github.io/sssom/reviewer_label/> rdfs:label "has reviewer_label" .
  
  <https://mapping-commons.github.io/sssom/see_also/> rdfs:label "has see_also" .
  
  <https://mapping-commons.github.io/sssom/semantic_similarity_measure/> rdfs:label
