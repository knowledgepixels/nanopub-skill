sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  rdf:type rdfs:label "is a" .
  
  <http://www.w3.org/2002/07/owl#AnnotationProperty> rdfs:label "owl:AnnotationProperty" .
  
  <http://www.w3.org/2002/07/owl#Class> rdfs:label "owl:Class" .
  
  <http://www.w3.org/2002/07/owl#DataProperty> rdfs:label "owl:DataProperty" .
  
  <http://www.w3.org/2002/07/owl#NamedIndividual> rdfs:label "owl:NamedIndividual" .
  
  <http://www.w3.org/2002/07/owl#ObjectProperty> rdfs:label "owl:ObjectProperty" .
  
  <http://www.w3.org/2002/07/owl#equivalentClass> rdfs:label "equivalentClass" .
  
  <http://www.w3.org/2002/07/owl#equivalentProperty> rdfs:label "equivalentProperty" .
  
  <http://www.w3.org/2002/07/owl#sameAs> rdfs:label "sameAs" .
  
  <http://www.w3.org/2004/02/skos/core#Concept> rdfs:label "skos:Concept" .
  
  <http://www.w3.org/2004/02/skos/core#broadMatch> rdfs:label "broadMatch" .
  
  <http://www.w3.org/2004/02/skos/core#closeMatch> rdfs:label "closeMatch" .
  
  <http://www.w3.org/2004/02/skos/core#exactMatch> rdfs:label "exactMatch" .
  
  <http://www.w3.org/2004/02/skos/core#narrowMatch> rdfs:label "narrowMatch" .
  
  <http://www.w3.org/2004/02/skos/core#relatedMatch> rdfs:label "relatedMatch" .
  
  <https://mapping-commons.github.io/semantic-mapping-vocabulary/#CompositeMatching>
    rdfs:label "Composite Matching" .
  
  <https://mapping-commons.github.io/semantic-mapping-vocabulary/#LexicalSimilarityThresholdMatching>
    rdfs:label "Lexical Similarity Threshold Matching" .
  
  <https://mapping-commons.github.io/semantic-mapping-vocabulary/#LogicalReasoning>
    rdfs:label "Logical Reasoning" .
  
  <https://mapping-commons.github.io/semantic-mapping-vocabulary/#ManualMappingCuration>
    rdfs:label "Manual Mapping Curation" .
  
  <https://mapping-commons.github.io/semantic-mapping-vocabulary/#MappingChaining> rdfs:label
      "Mapping Chaining" .
  
  <https://mapping-commons.github.io/semantic-mapping-vocabulary/#MappingReview> rdfs:label
