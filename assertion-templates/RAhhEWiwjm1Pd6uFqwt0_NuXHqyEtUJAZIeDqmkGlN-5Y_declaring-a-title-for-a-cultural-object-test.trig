sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  dct:title rdfs:label "has the title - connects the cultural object to a title describing it" .
  
  sub:assertion a nt:AssertionTemplate;
    rdfs:label "Declaring a title for a cultural object (test)";
    nt:hasNanopubLabelPattern "Title for ${object}: ${title}";
    nt:hasRequiredPubinfoElement <http://purl.org/np/RA5gNHxO43rlquxhEeAvFs5OCms5eaumzn--jqUu6g5HA>;
    nt:hasStatement sub:st1;
    nt:hasTag "Cultural Heritage";
    nt:hasTargetNanopubType <https://www.wikidata.org/entity/Q210272> .
  
  sub:object a nt:ExternalUriPlaceholder;
    rdfs:label "The URL/URI of the cultural object" .
  
  sub:st1 rdf:object sub:title;
    rdf:predicate dct:title;
    rdf:subject sub:object .
  
  sub:title a nt:LiteralPlaceholder;
    rdfs:label "the title of the object" .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo orcid:0000-0002-1267-0234 .
}

