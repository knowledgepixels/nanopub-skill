    gen:hasActionTemplate <https://w3id.org/np/RAG5csP7YFDy9Ddai27pI5njfE-qY53jgOwagVQkcYS0w>;
    gen:hasActionTemplatePartField "void";
    gen:hasActionTemplateQueryMapping "void";
    gen:hasActionTemplateTargetField "project" .
  
  sub:reused-datasets-project-view a gen:ResourceView, gen:TabularView;
    dct:isVersionOf sub:reused-datasets-project-view-kind;
    dct:title "♻️ Reused datasets";
    rdfs:label "Reused datasets for project view";
    gen:appliesToInstancesOf gen:Space;
    gen:hasStructuralPosition "4.7.reuse";
    gen:hasViewAction sub:addAction;
    gen:hasViewQuery <https://w3id.org/np/RAC8m77GXg7Zn6Jh0pDNvCXHx2MPE_CDfmXYMllCHyh1s/get-project-reused-datasets>;
