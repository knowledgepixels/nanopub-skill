    gen:hasActionTemplateTargetField "void" .
  
  sub:all-spaces-view a gen:ResourceView, gen:TabularView;
    dct:isVersionOf <https://w3id.org/np/RANB1bHSVXw8W0aFTvPURWpq960qJm9jEsI1rUDxXwMDY/all-spaces-view-kind>;
