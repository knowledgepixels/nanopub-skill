sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:profile-view a gen:ResourceView, gen:TabularView;
    dct:isVersionOf <https://w3id.org/np/RAVqZpaz5VYpuN25GfKPbgEIjP_lU8n_VZs1Qx06qVpbM/profile-view-kind>;
    dct:title "👤 Profile";
    rdfs:label "Profile view";
    gen:hasStructuralPosition "5.5.profile";
    gen:hasViewAction sub:updateImageAction, sub:updateLicenseAction;
    gen:hasViewQuery <https://w3id.org/np/RAe1tXq9916ABOqvVXQXmBJcx1l2EMXVBrBHda7CqIWIs/get-user-profile-info>;
    gen:hasViewQueryTargetField "user" .
  
  sub:updateImageAction a gen:ViewResultAction;
    rdfs:label "update profile image...";
    gen:hasActionTemplate <https://w3id.org/np/RAV6PgoKtIc5pkI0AXRbmwRlTFpA-DHytaZfEFGq3OTjo>;
    gen:hasActionTemplatePartField "void";
    gen:hasActionTemplateQueryMapping "void";
    gen:hasActionTemplateTargetField "user" .
  
  sub:updateLicenseAction a gen:ViewResultAction;
    rdfs:label "update profile license...";
    gen:hasActionTemplate <https://w3id.org/np/RAFmIDts27rRMUzK1HVdrVQTig4bJyr8mqzgzR5ulB2T0>;
    gen:hasActionTemplatePartField "void";
    gen:hasActionTemplateQueryMapping "void";
    gen:hasActionTemplateTargetField "user" .
}

