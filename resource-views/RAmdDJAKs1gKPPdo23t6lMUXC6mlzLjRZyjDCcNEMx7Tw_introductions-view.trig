    gen:hasActionTemplate <https://w3id.org/np/RA0QOsYNphQCityVcDIJEuldhhuJOX3GlBLw6QylRBhEI>;
    gen:hasActionTemplatePartField "void";
    gen:hasActionTemplateQueryMapping "retract_target:nanopubToBeRetracted";
    gen:hasActionTemplateTargetField "void" .
}

