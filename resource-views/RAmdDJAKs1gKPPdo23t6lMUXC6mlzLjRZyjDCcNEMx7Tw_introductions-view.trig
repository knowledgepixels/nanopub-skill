    gen:hasActionTemplate <https://w3id.org/np/RAT8ayO62s4SFqDY1qjv24Iw0xarpbpc6zH68n7hRsAsA>;
    gen:hasActionTemplatePartField "void";
    gen:hasActionTemplateQueryMapping "derive_target:@derive-a local_pubkey:public-key__.1 local_pubkey_short:key-declaration__.1 local_pubkey_short:key-declaration-ref__.1 site_url:key-location__.1";
    gen:hasActionTemplateTargetField "void" .
  
  sub:introductions-view a gen:ResourceView, gen:TabularView;
    dct:isVersionOf <https://w3id.org/np/RABbGzAaESdtU2ZG4Ar5fnwcUiV4kpFMp_k5p-6wOnc_s/introductions-view-kind>;
    dct:title "👋 Introductions";
    rdfs:label "Introductions view";
    gen:hasStructuralPosition "5.5.introductions";
    gen:hasViewAction sub:derive-action, sub:retract-action;
    gen:hasViewQuery <https://w3id.org/np/RA4k6eIjciIqSaQXv836fgVVASHm99UVIaZZhc_lF8IOU/get-user-introductions>;
    gen:hasViewQueryTargetField "user" .
  
  sub:retract-action a gen:ViewEntryAction;
