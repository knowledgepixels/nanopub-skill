sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:add-open-ended-subspace a gen:ViewResultAction;
    rdfs:label "add open-ended";
    gen:hasActionTemplate <https://w3id.org/np/RAgrIys3ge48pXrL_qNE0Rt1DHnIP8Rl2_29BnacMqYYY>;
    gen:hasActionTemplatePartField "space";
    gen:hasActionTemplateQueryMapping "void";
    gen:hasActionTemplateTargetField "void" .
  
  sub:add-time-limited-subspace a gen:ViewResultAction;
    rdfs:label "add time-limited";
    gen:hasActionTemplate <https://w3id.org/np/RAiuySO2dFpNoNdE0XLPiMlyZSVkIaD-INxaAq7yL4UGY>;
    gen:hasActionTemplatePartField "space";
    gen:hasActionTemplateQueryMapping "void";
    gen:hasActionTemplateTargetField "void" .
  
  sub:sub-spaces-view a gen:ListView, gen:ResourceView;
    dct:isVersionOf <https://w3id.org/np/RATTQW5C6_fb2vNX1nx7aBnHj6BktVye82UCP9U8WmCNM/sub-spaces-view-kind>;
    dct:title "🌎 Sub-spaces";
    rdfs:label "Sub-spaces view";
    gen:appliesToInstancesOf gen:Space;
    gen:hasDisplayWidth gen:ColumnWidth06of12;
    gen:hasStructuralPosition "2.7.subSpaces";
    gen:hasViewAction sub:add-open-ended-subspace, sub:add-time-limited-subspace;
    gen:hasViewQuery <https://w3id.org/np/RAWHT3OFty98KB3IUP3Cc2dusVh8-8V9OxlLDPqpGWkFQ/list-sub-spaces>;
    gen:hasViewQueryTargetField "space" .
}

